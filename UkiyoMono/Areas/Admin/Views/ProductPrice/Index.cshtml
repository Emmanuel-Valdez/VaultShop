@model FinalPriceVM
<div class="card shadow border-0 my-4">
	<div class="card-header bg-primary bg-gradient ml-0 py-3">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-secondary">@Localizer["FinalPrices"]</h2>
			</div>
		</div>
	</div>
	<div class="card-body p-4">
		<form method="post" class="d-flex justify-content-center p-3">
			@Html.AntiForgeryToken()
			@if (Model.CountOutdated > 0)
			{
				<input asp-for="CountOutdated" hidden />
				<button asp-action="UpdatePrices" class="btn btn-secondary my-1 fs-4 " style="width: auto;">
					@Localizer["Update"] @Model.CountOutdated @(Model.CountOutdated == 1 ? Localizer["ProductPrice"] : Localizer["ProductPrices"])
				</button>
			}
		</form>
		<div class="border rounded-3 bg-body-tertiary p-3 mb-4">
			<div class="mb-3">
				<h3 class="h5 mb-1">@Localizer["PricingSettings"]</h3>
				<p id="pricing-settings-help" class="small text-muted mb-0">@Localizer["PricingSettingsDescription"]</p>
			</div>
			<div class="row g-3 align-items-stretch">
				<div class="col-12 col-xl-5">
					<section class="h-100 border rounded-3 bg-body p-3" aria-labelledby="cost-totals-heading">
						<h4 id="cost-totals-heading" class="h6 text-uppercase text-muted fw-semibold mb-3">@Localizer["CostTotals"]</h4>
						<div class="row g-2">
							<div class="col-12 col-sm-6 col-xl-12">
								<div class="border rounded-3 p-3 h-100">
									<div class="small text-muted mb-1">@Localizer["RetailCostTotal"]</div>
									<div class="fs-4 fw-semibold text-body">@($"{Model.TotalPercentageCost.TotalPercentage:N2}%")</div>
								</div>
							</div>
							<div class="col-12 col-sm-6 col-xl-12">
								<div class="border rounded-3 p-3 h-100">
									<div class="small text-muted mb-1">@Localizer["WholesaleCostTotal"]</div>
									<div class="fs-4 fw-semibold text-body">@($"{Model.TotalPercentageCostWholesale.TotalPercentage:N2}%")</div>
								</div>
							</div>
						</div>
					</section>
				</div>
				<div class="col-12 col-xl-7">
					<form method="post" class="h-100" aria-describedby="pricing-settings-help">
						@Html.AntiForgeryToken()
						<input asp-for="CountOutdated" hidden />
						<section class="h-100 border rounded-3 bg-body p-3" aria-labelledby="profit-percentages-heading">
							<h4 id="profit-percentages-heading" class="h6 text-uppercase text-muted fw-semibold mb-3">@Localizer["ProfitPercentages"]</h4>
							<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
							<div class="row g-3 align-items-end">
								<div class="col-12 col-md-6">
									<label asp-for="PercentageProfit.Retail" class="form-label fw-semibold">@Localizer["RetailProfit"]</label>
									<div class="input-group">
										<input asp-for="PercentageProfit.Retail" class="form-control" inputmode="decimal" />
										<span class="input-group-text text-dark">%</span>
									</div>
									<span asp-validation-for="PercentageProfit.Retail" class="text-danger small"></span>
								</div>
								<div class="col-12 col-md-6">
									<label asp-for="PercentageProfit.Wholesale" class="form-label fw-semibold">@Localizer["WholesaleProfit"]</label>
									<div class="input-group">
										<input asp-for="PercentageProfit.Wholesale" class="form-control" inputmode="decimal" />
										<span class="input-group-text text-dark">%</span>
									</div>
									<span asp-validation-for="PercentageProfit.Wholesale" class="text-danger small"></span>
								</div>
								<div class="col-12 d-grid d-md-flex justify-content-md-end">
									<button type="submit" asp-action="Index" class="btn btn-primary">@Localizer["UpdateProfits"]</button>
								</div>
							</div>
						</section>
					</form>
				</div>
			</div>
		</div>
		<table id="tblData" class="table table-bordered table-striped table-hover"
			   data-price-current="@Localizer["PriceCurrent"]"
			   data-price-outdated="@Localizer["PriceOutdated"]"
			   data-product-available="@Localizer["ProductAvailable"]"
			   data-product-unavailable="@Localizer["ProductUnavailable"]">
			<thead>
				<tr>
					<th>@Localizer["ProductName"]</th>
					<th>@Localizer["Category"]</th>
					<th>@Localizer["ShippingCostByCategory"]</th>
					<th>@Localizer["TotalCost"]</th>
					<th>@Localizer["RetailWithProfit"]</th>
					<th>@Localizer["RetailWithShipping"]</th>
					<th>@Localizer["CurrentRetailPrice"]</th>
					<th>@Localizer["SuggestedRetailPrice"]</th>
					<th>@Localizer["CurrentWholesalePrice"]</th>
					<th>@Localizer["SuggestedWholesalePrice"]</th>
					<th>@Localizer["IsAvailable"]</th>
				</tr>
			</thead>
		</table>
	</div>
</div>
@section Scripts {
	<script src="~/js/finalPrice.js"></script>
}
