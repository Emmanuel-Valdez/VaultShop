@model ProductVM

<div class="card shadow border-0 my-4 admin-product-upsert">
	<div class="card-header bg-primary bg-gradient ml-0 py-4">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-secondary">@(Model.Product.Id != 0 ? Localizer["Update"] : Localizer["Create"]) @Localizer["Product"]</h2>
			</div>
		</div>
	</div>
	<div class="card-body p-4">
		<div class="row g-4">
			<div class="col-12 col-lg-8">
				<form method="post" class="row" enctype="multipart/form-data">
					@Html.AntiForgeryToken()
					<input asp-for="Product.Id" hidden />
					<input asp-for="Product.ListPrice" hidden />
					<input asp-for="Product.FinalWholesalePrice" hidden />
					<div class="border rounded-3 p-3 p-lg-4 bg-body-tertiary">
						<div asp-validation-summary="All" class="text-danger"></div>
						<div class="mb-3">
							<div class="form-floating mb-3 col-md-12 shadow">
								<input asp-for="Product.Name" class="form-control" placeholder="Name" />
								<label asp-for="Product.Name" class="ms-2 text-muted">@Localizer["Name"]</label>
							</div>
							<span asp-validation-for="Product.Name" class="text-danger"></span>
						</div>
						<div class="formform-floating py-2 col-12">
							<label asp-for="Product.Description" class="ms-2 text-muted ">@Localizer["Description"]</label>
							<textarea asp-for="Product.Description" class="form-control border-0 shadow js-rich-text"></textarea>
						</div>
						<div class="mb-3 col-md-12 shadow">
							<div class="input-group mb-3">
								<span class="input-group-text text-dark">$</span>
								<div class="form-floating">
									<input asp-for="Product.ListPrice" disabled class="form-control" placeholder="ListPrice" />
									<label asp-for="Product.ListPrice" class="ms-2 text-muted">@Localizer["ListPrice"]</label>
								</div>
							</div>
						</div>
					
						<div class="mb-3 col-md-12 shadow">
							<div class="input-group mb-3">
								<span class="input-group-text text-dark">$</span>
								<div class="form-floating">
									<input asp-for="Product.FinalWholesalePrice" disabled class="form-control" placeholder="FinalWholesalePrice" />
									<label asp-for="Product.FinalWholesalePrice" class="ms-2 text-muted">@Localizer["WholesalePrice"]</label>
								</div>
							</div>
						</div>
						<div class="mb-3">
							<div class="mb-3 col-md-12 shadow">
								<div class="input-group mb-3">
									<span class="input-group-text text-dark">$</span>
									<div class="form-floating">
										<input asp-for="Product.FinalRetailPrice" class="form-control" placeholder="Retail Price" />
										<label asp-for="Product.FinalRetailPrice" class="ms-2 text-muted">@Localizer["RetailPrice"]</label>
									</div>
								</div>
							</div>
							<span asp-validation-for="Product.FinalRetailPrice" class="text-danger"></span>
						</div>

						<div class="py-3 col-12">
							<label asp-for="Product.ProductImages" class="form-label fw-semibold">@Localizer["ProductImages"]</label>
							<input type="file" name="files" class="form-control shadow-sm" multiple accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
							<div class="form-text">@Localizer["ProductImagesHelp"]</div>
						</div>
						<div class="py-2 col-12">
							<label asp-for="Product.CategoryId" class="form-label fw-semibold">@Localizer["Category"]</label>
							<select asp-for="@Model.Product.CategoryId" asp-items="@Model.CategoryList" class="form-select border-0 shadow">
								<option disabled selected>--@Localizer["SelectCategory"]--</option>
							</select>

							<span asp-validation-for="Product.CategoryId" class="text-danger"></span>
						</div>
						<div class="form-check form-switch py-2 col-12">
							<input asp-for="Product.IsAvailableInStore" class="form-check-input" role="switch" />
							<label asp-for="Product.IsAvailableInStore" class="form-check-label ms-2">@Localizer["AvailableInStore"]</label>
						</div>
						<div class="row mt-3">
							<div class="col-6 col-md-3">
								@if (Model.Product.Id != 0)
								{
									<button type="submit" class="btn btn-primary form-control">@Localizer["Update"]</button>
								}
								else
								{
									<button type="submit" class="btn btn-primary form-control">@Localizer["Create"]</button>
								}

							</div>
							<div class="col-6 col-md-3">
								<a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary border form-control">
									@Localizer["BackToList"]	
								</a>
							</div>
						</div>
					</div>
				</form>
			</div>
			<div class="col-12 col-lg-4">
				<div class="border rounded-3 p-3 h-100">
					<div class="d-flex justify-content-between align-items-center mb-3">
						<h3 class="h5 mb-0 text-primary">@Localizer["ProductImages"]</h3>
						<span class="badge text-bg-secondary">@(Model.Product.ProductImages?.Count ?? 0)</span>
					</div>
					@if (Model.Product.ProductImages?.Any() == true)
					{
						<div class="row g-3">
							@foreach (var image in Model.Product.ProductImages.OrderedForDisplay())
							{
								<div class="col-6 col-lg-12">
									<div class="product-image-card border rounded-3 p-2 text-center h-100">
										<img src="@image.ImageUrl" class="product-image-card__image rounded" alt="@(Localizer["ProductImageAlt", Model.Product.Name])" />
							@if (image.IsPrimary)
							{
								<span class="badge bg-success d-block my-2">@Localizer["CoverImage"]</span>
							}
							else
							{
								<form asp-action="SetPrimaryImage" method="post" class="my-2">
									@Html.AntiForgeryToken()
									<input type="hidden" name="productId" value="@Model.Product.Id" />
									<input type="hidden" name="imageId" value="@image.Id" />
									<button type="submit" class="btn btn-outline-primary btn-sm w-100">
										@Localizer["SetAsCover"]
									</button>
								</form>
							}
							<a asp-action="DeleteImage" class="btn btn-outline-danger btn-sm w-100" asp-route-imageId="@image.Id">
								<i class="bi bi-trash-fill"></i> @Localizer["Delete"]
							</a>
									</div>
								</div>
							}
						</div>
					}
					else
					{
						<div class="empty-state rounded-3 p-4 text-center text-muted">
							<i class="bi bi-images fs-2 d-block mb-2" aria-hidden="true"></i>
							@Localizer["ProductImagesHelp"]
						</div>
					}
				</div>
			</div>
		</div>
	</div>
</div>


@section Scripts {
	@{
		<partial name="_ValidationScriptsPartial" />
	}
}
