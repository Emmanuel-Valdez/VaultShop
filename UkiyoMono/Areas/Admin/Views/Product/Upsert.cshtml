@model ProductVM

<div class="card shadow border-0 my-4 ">
	<div class="card-header bg-primary bg-gradient ml-0 py-4">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-secondary">@(Model.Product.Id != 0 ? Localizer["Update"] : Localizer["Create"]) @Localizer["Product"]</h2>
			</div>
		</div>
	</div>
	<div class="card-body p-4">
		<form method="post" class="row" enctype="multipart/form-data">
			@Html.AntiForgeryToken()
			<input asp-for="Product.Id" hidden />
			<input asp-for="Product.ListPrice" hidden />
			<input asp-for="Product.FinalWholesalePrice" hidden />
			<div class="row">
				<div class="col-12 col-md-10">
					<div class=" border p-3 ">
						<div asp-validation-summary="All" class="text-danger"></div>
						<div class="mb-3">
							<div class="form-floating mb-3 col-md-12 shadow">
								<input asp-for="Product.Name" class="form-control" placeholder="Name" />
								<label asp-for="Product.Name" class="ms-2 text-muted">@Localizer["Name"]</label>
							</div>
							<span asp-validation-for="Product.Name" class="text-danger"></span>
						</div>
						<div class="formform-floating py-2 col-12">
							<label asp-for="Product.Description" class="ms-2 text-muted ">@Localizer["Description"]</label>
							<textarea asp-for="Product.Description" class="form-control border-0 shadow"></textarea>
						</div>
						<div class="mb-3 col-md-12 shadow">
							<div class="input-group mb-3">
								<span class="input-group-text text-dark">$</span>
								<div class="form-floating">
									<input asp-for="Product.ListPrice" disabled class="form-control" placeholder="ListPrice" />
									<label asp-for="Product.ListPrice" class="ms-2 text-muted">@Localizer["ListPrice"]</label>
								</div>
							</div>
						</div>
					
						<div class="mb-3 col-md-12 shadow">
							<div class="input-group mb-3">
								<span class="input-group-text text-dark">$</span>
								<div class="form-floating">
									<input asp-for="Product.FinalWholesalePrice" disabled class="form-control" placeholder="FinalWholesalePrice" />
									<label asp-for="Product.FinalWholesalePrice" class="ms-2 text-muted">@Localizer["WholesalePrice"]</label>
								</div>
							</div>
						</div>
						<div class="mb-3">
							<div class="mb-3 col-md-12 shadow">
								<div class="input-group mb-3">
									<span class="input-group-text text-dark">$</span>
									<div class="form-floating">
										<input asp-for="Product.FinalRetailPrice" class="form-control" placeholder="Retail Price" />
										<label asp-for="Product.FinalRetailPrice" class="ms-2 text-muted">@Localizer["RetailPrice"]</label>
									</div>
								</div>
							</div>
							<span asp-validation-for="Product.FinalRetailPrice" class="text-danger"></span>
						</div>

						<div class="formform-floating py-2 col-12">
							<label asp-for="Product.ProductImages" class="ms-2">@Localizer["ProductImages"]</label>
							<input type="file" name="files" class="form-control border-0 shadow" multiple />
						</div>
						<div class="formform-floating py-2 col-12">
							<label asp-for="Product.CategoryId" class="ms-2">@Localizer["Category"]</label>
							<select asp-for="@Model.Product.CategoryId" asp-items="@Model.CategoryList" class="form-select border-0 shadow">
								<option disabled selected>--@Localizer["SelectCategory"]--</option>
							</select>

							<span asp-validation-for="Product.CategoryId" class="text-danger"></span>
						</div>
						<div class="form-check form-switch py-2 col-12">
							<input asp-for="Product.IsAvailableInStore" class="form-check-input" role="switch" />
							<label asp-for="Product.IsAvailableInStore" class="form-check-label ms-2">@Localizer["AvailableInStore"]</label>
						</div>
						<div class="row mt-3">
							<div class="col-6 col-md-3">
								@if (Model.Product.Id != 0)
								{
									<button type="submit" class="btn btn-primary form-control">@Localizer["Update"]</button>
								}
								else
								{
									<button type="submit" class="btn btn-primary form-control">@Localizer["Create"]</button>
								}

							</div>
							<div class="col-6 col-md-3">
								<a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary border form-control">
									@Localizer["BackToList"]	
								</a>
							</div>
						</div>
					</div>
				</div>
				<div class=" d-flex d-md-block col-4 col-md-2">
					@if (Model.Product.ProductImages != null)
					{
						foreach (var image in Model.Product.ProductImages)
						{
							<div class="border p-1 m-2 text-center">
								<img src="@image.ImageUrl" width="100%"
									 style="border-radius:5px; border:1px solid #bbb9b9" />
								<a asp-action="DeleteImage" class="btn btn-danger m-1" asp-route-imageId="@image.Id">
									<i class="bi bi-trash-fill"></i> @Localizer["Delete"]
								</a>
							</div>
						}
					}
				</div>
			</div>
		</form>
	</div>
</div>


@section Scripts {
	<script>
		tinymce.init({
			selector: 'textarea',
			plugins: 'anchor autolink charmap codesample emoticons link lists searchreplace  ',
			toolbar: 'undo redo | blocks fontfamily fontsize | bold italic underline strikethrough | link | align | numlist bullist indent outdent | emoticons',
		});
	</script> 
	@{
		<partial name="_ValidationScriptsPartial" />
	}
}
