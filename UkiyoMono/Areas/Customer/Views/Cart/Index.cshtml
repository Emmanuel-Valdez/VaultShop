@model ShoppingCartVM

<form method="post">
	@Html.AntiForgeryToken()
	<br />
	<div class="card shadow border-0">
		<div class="card-header bg-secondary bg-gradient  ml-0 py-4">
			<div class="row px-4">
				<div class="col-6">
					<h4 class="pt-2 text-primary">
						@Localizer["ShoppingCart"]
					</h4>
				</div>
			</div>
		</div>
		<div class="card-body my-4">
			<div asp-validation-summary="All" class="text-danger"></div>
			<div class="row">
			</div>
			<div class="row mb-3 pb-3">
				<div class="col-12 col-md-10 offset-md-1 mb-4">
					<a asp-area="Customer" asp-Controller="Home" asp-action="Index" class="btn btn-primary text-uppercase btn-sm">
						<small>@Localizer["ContinueShopping"]</small>
					</a>
				</div>
				<div class="col-md-10 offset-md-1">
					@foreach (var item in Model.ShoppingCartList)
					{
						var primaryImage = item.Product.ProductImages.PrimaryOrFirstForDisplay();
						var imageUrl = primaryImage?.ImageUrl ?? "https://placehold.co/500x600/png";
						var imageAlt = primaryImage is null ? $"No product image available for {item.Product.Name}" : item.Product.Name;
						<div class="row border-bottom pb-3 gy-3">
							<div class="col-3 col-sm-2 col-lg-1 text-center py-2">
								<a asp-action="Details" asp-controller="Home" asp-route-productId="@item.Product.Id" class="product-card__image-link rounded">
									<img src="@imageUrl" class="product-card__image" alt="@imageAlt" />
								</a>
							</div>
							<div class="col-9 col-sm-10 col-lg-5 pt-2 pt-md-3">
								@if (!string.IsNullOrWhiteSpace(item.Product.Category?.Name))
								{
									<p class="product-card__meta mb-1">@item.Product.Category.Name</p>
								}
								<a asp-action="Details" asp-controller="Home" asp-route-productId="@item.Product.Id" class="text-decoration-none">
									<h5 class="text-uppercase" ><strong>@item.Product.Name</strong></h5>
								</a>
								<div class="d-none d-md-block small">@Html.Raw(item.Product.Description)</div>
							</div>
							<div class="col-12 col-lg-5 row text-center align-items-center gy-2">
								<div class="col-12 col-sm-4 pt-2 pt-md-4">
									<h6 class="fw-semibold">
										@item.Price.ToString("c")
										<span class="text-muted">&nbsp;x&nbsp;</span>@item.Count
									</h6>
								</div>
								<div class="col-8 col-sm-5 pt-2">
									<div class="btn-group" role="group">
										<button type="submit" asp-action="Plus" asp-route-cartId="@item.Id" class="btn btn-outline-primary bg-gradient py-2">
											<i class="bi bi-plus-square"></i>
										</button> &nbsp;
										<button type="submit" asp-action="Minus" asp-route-cartId="@item.Id" class="btn btn-outline-primary bg-gradient py-2">
											<i class="bi bi-dash-square"></i>
										</button>
									</div>
								</div>
								<div class="col-4 col-sm-3 pt-2">
									<button type="submit" asp-action="Remove" asp-route-cartId="@item.Id" class="btn btn-danger bg-gradient py-2 ">
										<i class="bi bi-trash-fill"></i>
									</button>
								</div>
							</div>
						</div>
					}
				</div>
			</div>
			<div class="card-footer border-0">
				<div class="row">
					<div class="col-md-4 offset-md-4">
						<ul class="list-group mb-4">
							<li class="d-flex justify-content-between align-items-center">
								<h5 class=" fw-semibold text-uppercase"> Total</h5>
								<h4 class=" fw-bolder">@Model.OrderHeader.OrderTotal.ToString("c") </h4>
							</li>
						</ul>
					</div>
				</div>
				<div class="row">
					<div class="col-md-2 offset-md-5">
						<a asp-action="Summary" class="btn btn-primary border-0 bg-gradient  py-2 @(Model.OrderHeader.OrderTotal == 0 ? "disabled" : "")">@Localizer["Summary"]</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</form>
@section Scripts {
	@{
		<partial name="_ValidationScriptsPartial" />
	}
}
