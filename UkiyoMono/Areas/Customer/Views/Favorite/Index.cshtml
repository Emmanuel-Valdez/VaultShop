@model IEnumerable<FavoriteProduct>

<form method="post">
	@Html.AntiForgeryToken()
	<br />
	<div class="card shadow border-0">
		<div class="card-header bg-secondary bg-gradient  ml-0 py-4">
			<div class="row px-4">
				<div class="col-6">
					<h4 class="pt-2 text-primary">
						@Localizer["Title"]
					</h4>
				</div>

			</div>
		</div>
		<div class="card-body my-4">

			<div class="row">
			</div>
			<div class="row mb-3 pb-3">
				<div class="col-md-2 offset-md-1">
					<a asp-area="Customer" asp-Controller="Home" asp-action="Index" class="btn btn-primary text-uppercase mb-5 btn-sm">
						<small>@Localizer["ContinueShopping"]</small>
					</a>
				</div>
				<div class="col-md-10 offset-md-1">

					@foreach (var item in Model)
					{
						<div class="row border-bottom pb-3">
							<div class="d-none d-lg-block col-lg-1 text-center py-2">
								@if (item.Product.ProductImages != null && item.Product.ProductImages.Count() > 0)
								{
									<a asp-action="Details" asp-controller="Home"  asp-route-productId="@item.Product.Id">
										<img src="@item.Product.ProductImages.First().ImageUrl" class="card-img-top rounded w-100" />
									</a>
									
								}
								else
								{
									<a asp-action="Details" asp-controller="Home" asp-route-productId="@item.Product.Id">
										<img src="https://placehold.co/500x600/png" class="card-img-top rounded w-100" />
									</a>
									
								}
							</div>
							<div class="col-12 col-lg-5 pt-md-3">
								<a asp-action="Details" asp-controller="Home" asp-route-productId="@item.Product.Id" class="text-decoration-none">
									<h5 class="text-uppercase "><strong>@item.Product.Name</strong></h5>
								</a>
								
								<p><small>@Html.Raw(item.Product.Description)</small></p>
							</div>
							<div class="col-12  col-lg-5 text-center row">
								<div class="col-4 text-sm-right pt-2 pt-md-4">
									<h6 class="fw-semibold">
										@item.Product.FinalRetailPrice.ToString("c")

									</h6>
								</div>

								<div a class="col-3 col-sm-4 col-lg-2 offset-lg-1 text-right pt-2">
									<button type="submit" asp-action="RemoveFromIndex" asp-route-favoriteId="@item.Id" class="btn btn-danger bg-gradient py-2 ">
										<i class="bi bi-trash-fill"></i>
									</button>
								</div>
							</div>

						</div>

					}

				</div>
			</div>

		</div>
	</div>
</form>
