@using Microsoft.AspNetCore.Identity
@model ShoppingCart
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = Model.Product.Name;
    ViewData["Description"] = Model.Product.Description?.Length > 150 ? Model.Product.Description.Substring(0, 150) + "..." : Model.Product.Description ?? string.Format(Localizer["ProductFallbackDescription"].Value, Model.Product.Name);
    ViewData["Keywords"] = $"{Model.Product.Name}, {Model.Product.Category.Name}, {Localizer["MetaKeywordsSuffix"].Value}";
    var imageUrl = Model.Product.ProductImages?.FirstOrDefault()?.ImageUrl ?? $"{SD.SiteUrl}/images/marca.png";
    ViewData["OgImage"] = imageUrl;
}

<script type="application/ld+json">
{
    "@( "@" )context": "https://schema.org",
    "@( "@" )type": "Product",
    "name": "@Model.Product.Name",
    "description": "@Html.Raw(Model.Product.Description?.Replace("\"", "'"))",
    "image": "@imageUrl",
    "offers": {
        "@( "@" )type": "Offer",
        "priceCurrency": "ARS",
        "price": "@Model.Product.FinalRetailPrice.ToString("F2")",
        "availability": "https://schema.org/InStock"
    },
    "brand": {
        "@( "@" )type": "Brand",
        "name": "Ukiyo"
    }
}
</script>

<form method="post">

	<div class="card shadow border-0 mt-4 mb-4 ">
		<div class="card-header  bg-primary bg-gradient  text-light py-4">
			<div class="row">
				<div class="col-12 text-center">
					<h3 class="text-secondary text-uppercase">@Model.Product.Name</h3>
					<p class="text-secondary fw-semibold mb-0">@Localizer["InspiredBy"]</p>
				</div>
			</div>
		</div>
		<div class="card-body bg-secondary rounded">
			<input asp-for="@Model.ApplicationUserId" hidden />
			<input asp-for="@Model.ProductId" hidden />
			<div class="py-3">
				<div class="row">
					<div class="col-6 col-md-2 offset-lg-1 pb-1">
						<a asp-action="Index" class="btn btn-outline-primary bg-gradient mb-5 fw-semibold btn-sm text-uppercase">
							<small>@Localizer["BackToHome"]</small>
						</a>
					</div>
				</div>
				<div class="row">
					<div class="col-12 col-lg-3 offset-lg-1 text-center mb-3">
						@if (Model.Product.ProductImages != null && Model.Product.ProductImages.Count > 0)
						{
							<div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="carousel">
								<div class="carousel-indicators">

									@foreach (var imageWithIndex in
																									Model.Product.ProductImages.Select((image, index) =>
																									new { Image = image, Index = index }))
									{
										<button type="button" data-bs-target="#carouselExampleIndicators"
										data-bs-slide-to="@imageWithIndex.Index" class="@(imageWithIndex.Index==0?"active":"")" aria-current="true" aria-label="Slide 1"></button>
									}
								</div>
								<div class="carousel-inner">
									@foreach (var imageWithIndex in
																									Model.Product.ProductImages.Select((image, index) =>
																									new { Image = image, Index = index }))
									{
										<div class="carousel-item @(imageWithIndex.Index==0?"active":"")">
											<img src="@imageWithIndex.Image.ImageUrl" class="d-block w-100" alt="@Model.Product.Name">
										</div>
									}
								</div>
								<button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
									<span class="carousel-control-prev-icon" aria-hidden="true"></span>
									<span class="visually-hidden">Previous</span>
								</button>
								<button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
									<span class="carousel-control-next-icon" aria-hidden="true"></span>
									<span class="visually-hidden">Next</span>
								</button>
							</div>
						}
					</div>
					<div class="col-12 col-lg-6 offset-lg-1">

						<div class="col-12  col-md-6 pb-4">
							<span class="badge text-dark">@Model.Product.Category.Name</span>
						</div>

						<div class="row ps-2">
							<h6 class=" text-opacity-50 text-dark  pb-2">
								@Localizer["Price"]:
							</h6>
						</div>
						@if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee) || User.IsInRole(SD.Role_Company))
						{
							<div class="row ps-2">
								<div class="h2 text-warning">
									<span class="text-decoration-line-through">
										@Model.Product.FinalRetailPrice.ToString("c")
									</span>
								</div>
							</div>
							<div class="row ps-2">
								<div class="h2 text-success ">@Model.Product.FinalWholesalePrice.ToString("c")</div>
							</div>
						}
						else
						{
							<div class="row ps-2">
								<div class="h2 text-success">
									@Model.Product.FinalRetailPrice.ToString("c")
								</div>
							</div>
						}
						
						<div class="row pl-2 my-3">
							<div class="theme-card bg-gradient">
								@Html.Raw(Model.Product.Description)
							</div>
						</div>

						<div class="row pl-2 mb-3">
							<div class="col-md-4">
								<div class="input-group mb-3 ">
									<span class="input-group-text bg-primary border-0 text-secondary fw-semibold"
										  id="inputGroup-sizing-default">
										@Localizer["Count"]
									</span>
									<input asp-for="Count" type="number" value="1" class="form-control text-end   shadow"
										   aria-label="Sizing example input" aria-describedby="inputGroup-sizing-default" />
									<span asp-validation-for="Count" class="text-danger"></span>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-12 col-md-8 pb-1 ">
								@if ((User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee) || User.IsInRole(SD.Role_Company)) && Model.Product.FinalWholesalePrice == 0)
								{
									<button class="col-9 col-md-6 btn btn-danger disabled bg-gradient py-2 text-uppercase fw-semibold ">
										@Localizer["TemporarilyUnavailable"]
									</button>
								}
								else
								{
									<button type="submit"
											class="col-9 col-md-6 btn btn-primary bg-gradient py-2 text-uppercase fw-semibold ">
										@Localizer["AddToCart"]
									</button>
								}
								@if (SignInManager.IsSignedIn(User))
								{
									@if (Model.IsFavorite == false)
									{
										<button class="col-2 col-md-2 btn btn-link text-primary fs-3" asp-action="Add" asp-controller="Favorite">
											<i class="bi bi-balloon-heart"></i>
										</button>
									}
									else
									{
										<button class="col-2 col-md-2 btn btn-link text-primary fs-3" asp-action="RemoveFromProductDetails" asp-controller="Favorite" asp-route-favoriteId="@Model.FavoriteProductId" asp-route-productId="@Model.ProductId">
											<i class="bi bi-balloon-heart-fill"></i>
										</button>
									}
								}
							</div>
						</div>
					</div>

				</div>
			</div>
		</div>
	</div>
</form>
@section Scripts {
	@{
		<partial name="_ValidationScriptsPartial" />
	}
}

