@model IEnumerable<Product>
@{
    ViewData["Title"] = @Localizer["Home"];
    ViewData["Description"] = "Ukiyo - Tu tienda de mercería y telas con descuentos mayoristas. Amplio catálogo de productos para costureras y profesionales de la confección. Envíos a todo Argentina.";
    ViewData["Keywords"] = "tienda merceria, telas descuento, herrajes confección, productos costureras, Argentina";
}

<div class="row pb-3  ">
	@foreach (var product in Model)
	{
		<div class="col-lg-3 col-sm-6">
			<div class="row p-2">
				<div class="col-12 p-1">
					<div class="card border-0 p-3 shadow border-top border-5 rounded bg-secondary ">
						@if(product.ProductImages!= null && product.ProductImages.Count() > 0)
						{
							<a asp-action="Details" asp-route-productId="@product.Id" >
								<img src="@product.ProductImages.FirstOrDefault().ImageUrl" class="card-img-top rounded " />
							</a>
							
						}else
						{
							<a asp-action="Details" asp-route-productId="@product.Id" >
								<img src="https://placehold.co/500x600/png" class="card-img-top rounded" />
							</a>
							
						}

						<div class="pl-1">
							<p class="card-title h5 text-primary text-uppercase text-center">@product.Name</p>
						</div>
						<div class="pl-1">
							<p class="text-center text-primary h5"><span>@product.FinalRetailPrice.ToString("c")</span></p>
						</div>
						<div>
							<a asp-action="Details" asp-route-productId="@product.Id" class="btn btn-primary bg-gradient border-0 form-control">
								@Localizer["Details"]
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	}
</div>

