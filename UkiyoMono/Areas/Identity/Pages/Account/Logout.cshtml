@page
@model LogoutModel


<header>
    <h1>@Localizer["LogOut"]</h1>
    @{
        if (User.Identity?.IsAuthenticated ?? false)
        {
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="nav-link btn btn-link text-dark" @Localizer["Click"]></button>
            </form>
        }
        else
        {
            <p>@Localizer["SuccessLogOut"]</p>
        }
    }
</header>
