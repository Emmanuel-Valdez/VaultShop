@page
@model IndexModel
@{
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3>@Localizer["Profile"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control shadow" placeholder="Please choose your username." disabled />
                <label asp-for="Username" class="form-label">@Localizer["Username"]</label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Name" class="form-control shadow" placeholder="Please enter your Full Name." />
                <label asp-for="Input.Name" class="form-label">@Localizer["Name"]</label>
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control shadow" placeholder="Please enter your phone number." />
                <label asp-for="Input.PhoneNumber" class="form-label">@Localizer["PhoneNumber"]</label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>
          
            <div class="form-floating mb-3">
                <input asp-for="Input.PostalCode" class="form-control shadow" placeholder="Please enter your Postal Code." />
                <label asp-for="Input.PostalCode" class="form-label">@Localizer["PostalCode"]</label>
                <span asp-validation-for="Input.PostalCode" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.StreetAddress" class="form-control shadow" placeholder="Please enter your Street Address." />
                <label asp-for="Input.StreetAddress" class="form-label">@Localizer["StreetAddress"]</label>
                <span asp-validation-for="Input.StreetAddress" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.City" class="form-control shadow" placeholder="Please enter your City." />
                <label asp-for="Input.City" class="form-label">@Localizer["City"]</label>
                <span asp-validation-for="Input.City" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.State" class="form-control shadow" placeholder="Please enter your State." />
                <label asp-for="Input.State" class="form-label">@Localizer["State"]</label>
                <span asp-validation-for="Input.State" class="text-danger"></span>
            </div>
            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">@Localizer["Save"]</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
