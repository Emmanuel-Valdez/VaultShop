{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Branding": {
    "PublicName": "VaultShop",
    "LogoPath": "/images/brand/vaultshop-logo.svg",
    "LogoDarkPath": "/images/brand/vaultshop-logo-dark.svg",
    "MarkPath": "/images/brand/vaultshop-mark.svg",
    "AppleTouchIconPath": "/images/brand/vaultshop-mark.svg",
    "SocialPreviewImagePath": "/images/brand/vaultshop-og.svg",
    "TwitterSite": "@VaultShop"
  },
  "Theme": {
    "Primary": "#1a2a4a",
    "PrimaryDark": "#0d1625",
    "Accent": "#d4a017",
    "Surface": "#f7f8fa",
    "SurfaceDark": "#1e2030"
  },
  "Database": {
    "RunMigrationsOnStartup": false
  },
  "ImageStorage": {
    "Provider": "Local",
    "Minio": {
      "Endpoint": "minio:9000",
      "UseSsl": false,
      "BucketName": "product-images",
      "AccessKey": "",
      "SecretKey": "",
      "PublicBaseUrl": "http://localhost:9000/product-images"
    }
  }
}
