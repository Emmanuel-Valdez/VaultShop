@using System.Globalization
@{
    Layout = "_Layout";
    var isSpanish = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es";
    ViewData["Description"] = ViewData["Description"] ?? (isSpanish
        ? "Ukiyo - Productos únicos inspirados en anime, cómics y fantasía. Mochilas, bolsos y accesorios hechos con cuidado en Argentina."
        : "Ukiyo - Unique anime, comic, and fantasy-inspired products. Backpacks, bags, and accessories carefully made in Argentina.");
    ViewData["Keywords"] = ViewData["Keywords"] ?? (isSpanish
        ? "Ukiyo, mochilas, bolsos, accesorios, anime, cómics, fantasía, Argentina"
        : "Ukiyo, backpacks, bags, accessories, anime, comics, fantasy, Argentina");
    ViewData["Robots"] = ViewData["Robots"] ?? "index, follow";
    ViewData["OgImage"] = ViewData["OgImage"] ?? $"{SD.SiteUrl}/images/marca.png";
}
