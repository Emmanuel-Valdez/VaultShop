@using UkiyoDesignsWeb
@using Microsoft.AspNetCore.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] Ukiyo</title>
	<link rel="icon" type="image/png" href="~/flor-de-cerezo.png" />
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
	<link rel="stylesheet" href=" //cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css">
	<link rel="stylesheet" href="~/UkiyoDesignsWeb.styles.css" asp-append-version="true" />
	<link rel="stylesheet" href=" https://cdn.datatables.net/2.1.7/css/dataTables.bootstrap5.css" />
	<link rel="stylesheet" href=" https://cdn.datatables.net/2.1.7/css/dataTables.dataTables.css" />
	<link rel="stylesheet" href=" https://cdn.datatables.net/responsive/3.0.3/css/responsive.bootstrap5.css" />
	<link rel="stylesheet" href=" https://cdn.datatables.net/buttons/3.1.2/css/buttons.dataTables.css" />
	<link rel="stylesheet" href=" https://cdn.datatables.net/responsive/3.0.3/css/responsive.dataTables.css" />
	<link rel="stylesheet" href=" https://cdn.datatables.net/2.1.8/css/dataTables.bootstrap5.css" />
	<link rel="stylesheet" href=" https://cdn.datatables.net/buttons/3.1.2/css/buttons.bootstrap5.css" />

	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />


</head>
<body>
	<header class="sticky-top">
		<nav class="navbar navbar-expand-lg d-flex bg-primary" aria-label="Main navigation">
			<div class="container-fluid">
				<a class="navbar-brand" asp-area="Customer" asp-controller="Home" asp-action="Index">
					<img src="/images/marca.png" style="width:60px" />
				</a>
				<button class="navbar-toggler collapsed border-0 " type="button" id="navbarSideTop"
						aria-label="Toggle navigation"
						data-bs-toggle="offcanvas"
						data-bs-target="#sideNavbarTop">
					<i class=" fs-2 bi bi-list text-secondary"></i>
				</button>
				<section class="offcanvas offcanvas-end bg-primary" id="sideNavbarTop" tabindex="-1">
					<div class="offcanvas-header ">
						<h5 class="offcanvas-title text-secondary text-center">@Localizer["Slogan"]</h5>
						<button class="btn-close" type="button" aria-label="Close" data-bs-dismiss="offcanvas"></button>
					</div>
					<div class="offcanvas-body d-flex flex-column justify-content-between px-3 ">
						<ul class="navbar-nav me-auto fs-5  flex-grow-1 ">
							<li class="nav-item p-sm-3 py-md-1 ">
								<a class="nav-link text-secondary" asp-area="Customer" asp-controller="Home" asp-action="Index">@Localizer["Home"]</a>
							</li>

							@if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee))
							{
								<li class="nav-item dropdown py-md-1 p-sm-3">
									<a class="nav-link dropdown-toggle text-secondary" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
										@Localizer["ContentManagment"]
									</a>
									<ul class="dropdown-menu">
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="Category" asp-action="Index">@Localizer["Category"]</a>
										</li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="Product" asp-action="Index">@Localizer["Product"]</a>
										</li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="Company" asp-action="Index">@Localizer["Company"]</a>
										</li>
										<li><hr class="dropdown-divider" /></li>
										<li class="nav-item">
											<a class="dropdown-item " asp-area="Identity" asp-page="/Account/Register">@Localizer["CreateUser"]</a>
										</li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="User" asp-action="Index">@Localizer["ManageUsers"]</a>
										</li>
									</ul>
								</li>
								<li class="nav-item dropdown py-md-1 p-sm-3">
									<a class="nav-link dropdown-toggle text-secondary" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
										@Localizer["CostCalculator"]
									</a>
									<ul class="dropdown-menu">
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="Packaging" asp-action="Index">@Localizer["Packaging"]</a>
										</li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="PackagingByCategory" asp-action="Index">@Localizer["PackagingByCategory"]</a>
										</li>
										<li><hr class="dropdown-divider" /></li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="Fabric" asp-action="Index">@Localizer["Fabric"]</a>
										</li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="FabricByProduct" asp-action="Index">@Localizer["FabricByProduct"]</a>
										</li>
										<li><hr class="dropdown-divider " /></li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="GarmentHardware" asp-action="Index">@Localizer["GarmentHardware"]</a>
										</li>
										<li class="nav-item">
											<a class="dropdown-item " asp-area="Admin" asp-controller="GarmentHardwareByProduct" asp-action="Index">@Localizer["GarmentHardwareByProduct"]</a>
										</li>
										<li><hr class="dropdown-divider" /></li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="FixedCost" asp-action="Index">@Localizer["FixedCost"]</a>
										</li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="PercentageCost" asp-action="Index">@Localizer["PercentageCost"]</a>
										</li>
										<li><hr class="dropdown-divider" /></li>
										<li class="nav-item">
											<a class="dropdown-item " asp-area="Admin" asp-controller="ProductPrice" asp-action="CostByProduct">@Localizer["CostByProduct"]</a>
										</li>
										<li class="nav-item ">
											<a class="dropdown-item " asp-area="Admin" asp-controller="ProductPrice" asp-action="Index">@Localizer["FinalPrice"]</a>
										</li>
									</ul>
								</li>
							}
							<li class="nav-item p-sm-3 py-md-1">
								<a class="nav-link text-secondary" asp-area="Admin" asp-controller="Order" asp-action="Index">@Localizer["ManageOrder"]</a>
							</li>

							@if (SignInManager.IsSignedIn(User))
							{
								<li class="nav-item p-sm-3 py-md-1">
									<a class="nav-link text-secondary" asp-area="Customer" asp-controller="Favorite" asp-action="Index">
										<i class="bi bi-heart-fill"></i> @Localizer["Favs"]
									</a>
								</li>
							}
						</ul>
						<form asp-area="Customer" asp-controller="Home" asp-action="Search" class="nav-item p-3 py-3 d-flex d-lg-none nav-justified" role="search" method="get">
							<input class="form-control me-2" name="searchString" type="search" placeholder="@Localizer["Search"]" aria-label="Search">
							<button class="btn btn-secondary" type="submit"><i class="bi bi-search-heart fs-4"></i> </button>
						</form>
						<div class="d-lg-none align-self-center py-3">
							<a href=""><i class="bi bi-tiktok px-2 text-secondary fs-2"></i></a>
							<a href=""><i class="bi bi-facebook px-2 text-secondary fs-2"></i></a>
							<a href=""><i class="bi bi-instagram px-2 text-secondary fs-2"></i></a>
							<a href=""><i class="bi bi-whatsapp px-2 text-secondary fs-2"></i></a>
						</div>
					</div>
				</section>
				<div class="nav-item">
					<a class="nav-link text-secondary fs-5 badge position-relative" asp-area="Customer" asp-controller="Cart" asp-action="Index">
						@await Component.InvokeAsync("ShoppingCart")
					</a>
				</div>
			</div>
		</nav>
	</header>
	<nav class="navbar navbar-expand-lg bg-secondary  ">
		<div class="container-fluid">
			<button class="navbar-toggler " type="button" id="navbarSideTop"
					aria-label="Toggle navigation"
					data-bs-toggle="offcanvas"
					data-bs-target="#sideNavbarLeft">
				<i class=" fs-2 bi bi-list text-primary"></i>
			</button>
			<section class="offcanvas  offcanvas-start bg-secondary" id="sideNavbarLeft" tabindex="-1">
				<div class="offcanvas-header border-bottom">
					<h5 class="offcanvas-title text-primary">@Localizer["Slogan"]</h5>
					<button class="btn-close btn-outline-primary" type="button" aria-label="Close" data-bs-dismiss="offcanvas"></button>
				</div>
				<div class="offcanvas-body  d-flex flex-column justify-content-between px-0 me-sm-3">
					<ul class="navbar-nav  me-auto fs-5 flex-grow-1 ">
						<li class="nav-item  ms-3">
							<a class="nav-link text-primary" asp-area="Customer" asp-controller="Home" asp-action="FAQs">@Localizer["FAQs"]</a>
						</li>
						<li class="nav-item  ms-3">
							<a class="nav-link text-primary" asp-area="Customer" asp-controller="Home" asp-action="AboutUs">@Localizer["AboutUs"]</a>
						</li>
						<li class="nav-item ms-3">
							<a class="nav-link text-primary" asp-area="Customer" asp-controller="Home" asp-action="TakeCare">@Localizer["TakeCare"]</a>
						</li>
						@if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee) || User.IsInRole(SD.Role_Company))
						{
							<li class="nav-item ms-3">
								<a class="nav-link text-primary" asp-area="Customer" asp-controller="Home" asp-action="Wholesale">@Localizer["Wholesale"]</a>
							</li>
						}
						<li class="nav-item ms-3">
							<a class="nav-link text-primary" asp-area="Customer" asp-controller="Home" asp-action="Privacy">@Localizer["Privacy"]</a>
						</li>
						@if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee))
						{
							<li class="nav-item ms-3">
								<a class="nav-link text-primary" asp-area="Customer" asp-controller="Home" asp-action="Help">@Localizer["Help"]</a>
							</li>
						}
					</ul>

					<div class="d-lg-none align-self-center py-3">
						<a href= @SD.TikTokLink
					   target="_blank"
					   rel="noopener"><i class="bi bi-tiktok px-2 icon-link fs-2"></i></a>
						<a href=@SD.FacebookLink
					   target="_blank"
					   rel="noopener"><i class="bi bi-facebook px-2 icon-link fs-2"></i></a>
						<a href=@SD.InstagramLink
					   target="_blank"
					   rel="noopener"><i class="bi bi-instagram px-2 icon-link fs-2"></i></a>
						<a href=@SD.WhatsAppLink
					   target="_blank"
					   rel="noopener"><i class="bi bi-whatsapp px-2 icon-link fs-2"></i></a>
					</div>
				</div>
			</section>

			<form asp-area="Customer" asp-controller="Home" asp-action="Search" class="d-flex nav-justified " role="search" method="get">
				<input class="form-control me-1" name="searchString" type="search" placeholder="@Localizer["Search"]" aria-label="Search">
				<button class="btn btn-outline-primary" type="submit"><i class="bi bi-search-heart fs-4"></i> </button>
			</form>
			<div class=" dropdown ms-1">
				<a class="nav-link text-primary mx-1" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
					<span class="d-none d-lg-inline fs-5"> @Localizer["MyAccount"]</span><i class="bi bi-person fs-4"></i>
				</a>
				<partial name="_loginPartial" />
			</div>

		</div>
	</nav>

	<div class="container">
		<main role="main" class="pb-3">
			<partial name="_Notification" />
			@RenderBody()
		</main>
	</div>
	<div class="container">
		<footer class="d-flex flex-wrap justify-content-between align-items-center py-3 my-4 border-top  bg-gradient rounded">
			<div class="col-md-4 d-flex align-items-center">
				<a class="navbar-brand px-4 " asp-area="" asp-controller="Home" asp-action="Index">
					<img src="/images/marca.png" style="width:80px" />
				</a>

				<div class="container text-primary">
					@Localizer["MadeBy"]
					<a class="text-decoration-none nav-link" href="@SD.EvalmonLink" 
					   target="_blank"
					   rel="noopener">EValMonDev</a>
				</div>
			</div>
			<div class="language-selector"> 
				<form method="post" asp-area="Customer" asp-controller="Home" asp-action="SetLanguage">
					<input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString.ToUriComponent())" />
					@if (System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "es-AR")
					{
						<button type="submit" name="culture" value="en-US" class="btn btn-outline-info">English</button>
					}
					else
					{
						<button type="submit" name="culture" value="es-AR" class="btn btn-outline-info">Español</button>
					} 
				</form> 
			</div>
			<div class="align-self-end py-3 ">
				<a href=@SD.TikTokLink
				   target="_blank"
				   rel="noopener"><i class="bi bi-tiktok px-2 icon-link fs-2"></i></a>
				<a href=@SD.FacebookLink
				   target="_blank"
				   rel="noopener"><i class="bi bi-facebook px-2 icon-link fs-2"></i></a>
				<a href=@SD.InstagramLink
				   target="_blank"
				   rel="noopener"><i class="bi bi-instagram px-2 icon-link fs-2"></i></a>
				<a href=@SD.WhatsAppLink
				   target="_blank"
				   rel="noopener"><i class="bi bi-whatsapp px-2 icon-link fs-2"></i></a>
			</div>
		</footer>
	</div>
	
	<partial name="_ThemeToggle" />
	<script type="text/javascript">
		var currentCulture = `@System.Threading.Thread.CurrentThread.CurrentUICulture.Name`
	</script>
	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	
	<script src="~/js/site.js" asp-append-version="true"></script>
	
	<script src="~/js/utils.js" asp-append-version="true"></script>
	<script src="//cdn.datatables.net/2.1.7/js/dataTables.min.js" asp-append-version="true"></script>
	<script src="https://cdn.datatables.net/2.1.8/js/dataTables.bootstrap5.js" asp-append-version="true"></script>
	<script src="https://cdn.datatables.net/responsive/3.0.3/js/dataTables.responsive.js"></script>
	<script src="https://cdn.datatables.net/responsive/3.0.3/js/responsive.bootstrap5.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
	<script src="https://cdn.tiny.cloud/1/i512xeptxidiq8degyguvy75e4q42t00srpxq6l3nnezm7v1/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>
	<script src="https://cdn.datatables.net/buttons/3.1.2/js/dataTables.buttons.js"></script>
	<script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.dataTables.js"></script>
	<script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.bootstrap5.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
	<script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.html5.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
	<script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.colVis.min.js"></script>
	<script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.print.min.js"></script>

	<script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>

	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
