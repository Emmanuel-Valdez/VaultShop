# Copy this file to .env.compose and replace placeholder values before running Docker Compose.
# Do not commit .env.compose.

APP_HTTP_PORT=8080
SQLSERVER_PORT=1433
DATABASE_RUN_MIGRATIONS_ON_STARTUP=false

# SQL Server requires a strong password: at least 8 chars with upper, lower, digit, and symbol.
MSSQL_SA_PASSWORD=Change_this_Strong_Password_123!

ConnectionStrings__DefaultConnection=Server=sqlserver,1433;Database=UkiyoDesigns;User Id=sa;Password=Change_this_Strong_Password_123!;TrustServerCertificate=True;Encrypt=True;MultipleActiveResultSets=True

Stripe__SecretKey=sk_test_replace_me
Stripe__PublishableKey=pk_test_replace_me
Stripe__WebhookSecret=whsec_replace_me

Facebook__AppId=replace_me
Facebook__AppSecret=replace_me

Email__Provider=Fake
Email__UseFakeEmailSender=true
Resend__ApiKey=re_replace_me
Resend__FromEmail=onboarding@resend.dev

Seed__AdminEmail=admin@example.local
Seed__AdminPassword=Change_this_Admin_Password_123!

SiteUrl=http://localhost:8080

Social__TikTok=https://example.local/tiktok
Social__WhatsApp=https://example.local/whatsapp
Social__Instagram=https://example.local/instagram
Social__Facebook=https://example.local/facebook
Social__DevLink=https://example.local/dev
