# Copy this file to .env.compose and replace placeholder values before running Docker Compose.
# Do not commit .env.compose.

APP_HTTP_BIND_IP=127.0.0.1
APP_HTTP_PORT=8080
# ASP.NET runtime environment only; branding stays in Branding__* values below.
APP_ASPNETCORE_ENVIRONMENT=Production
COMPOSE_PROJECT_NAME=vaultshop
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_PORT=5432
DATABASE_RUN_MIGRATIONS_ON_STARTUP=false

# Use unless-stopped on the VPS so containers recover after Docker/server restarts.
# Set to "no" in a local-only env file if you do not want Docker Desktop to restart them automatically.
DOCKER_RESTART_POLICY=unless-stopped

# MinIO local object storage
MINIO_BIND_IP=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=Change_this_MinIO_Password_123!
MINIO_BUCKET_NAME=product-images

# PostgreSQL local database. Keep these values in sync with the connection string below.
POSTGRES_DB=vaultshop
POSTGRES_USER=vaultshop_app
POSTGRES_PASSWORD=Change_this_Postgres_Password_123!

ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=vaultshop;Username=vaultshop_app;Password=Change_this_Postgres_Password_123!

Stripe__SecretKey=sk_test_replace_me
Stripe__PublishableKey=pk_test_replace_me
Stripe__WebhookSecret=whsec_replace_me

# Bank transfer payment method
Payments__BankTransferEnabled=true
Payments__StripeEnabled=true
Payments__MercadoPagoEnabled=false
Payments__MercadoPagoAccessToken=
Payments__MercadoPagoWebhookSecret=
Payments__BankTransferCbu=0000000000000000000000
Payments__BankTransferAlias=vaultshop.transferencia
Payments__BankTransferRecipientName=VaultShop
Payments__BankTransferBankName=Example Bank

# Facebook OAuth is optional; provide both values to enable it.
Facebook__AppId=
Facebook__AppSecret=

Email__Provider=Fake
Email__UseFakeEmailSender=true
Email__AdminEmail=admin@example.local
Resend__ApiKey=re_replace_me
Resend__FromEmail=onboarding@resend.dev

Seed__AdminEmail=admin@example.local
Seed__AdminPassword=Change_this_Admin_Password_123!

SiteUrl=http://localhost:8080

# Public branding. Future client deployments should override these values in their own private env file.
# Private assets should be mounted or copied outside git, for example /images/brand/vaultshop-logo.svg.
# Missing configured files intentionally return 404 so deployment checks catch bad mounts.
BrandAssetsPath=./VaultShop.Web/wwwroot/images/brand/private
Branding__PublicName=VaultShop
Branding__LogoPath=/images/brand/vaultshop-logo.svg
Branding__LogoDarkPath=/images/brand/vaultshop-logo-dark.svg
Branding__MarkPath=/images/brand/vaultshop-mark.svg
Branding__AppleTouchIconPath=/images/brand/vaultshop-mark.svg
Branding__SocialPreviewImagePath=/images/brand/vaultshop-og.svg
Branding__TwitterSite=@VaultShop
Storefront__ShowDemoNotice=true

# Set to /keys to persist Identity sessions across web-container recreation.
DataProtection__KeysPath=/keys
# Used only by docker-compose.store.yml; create the external volume before first use.
DATA_PROTECTION_VOLUME_NAME=vaultshop_data-protection-keys

# Public theme colors. Only hex colors are accepted by the app; invalid values fall back to VaultShop defaults.
Theme__Primary=#1a2a4a
Theme__PrimaryDark=#0d1625
Theme__Accent=#d4a017
Theme__Surface=#f7f8fa
Theme__SurfaceDark=#1e2030

Social__TikTok=https://example.local/tiktok
Social__WhatsApp=https://example.local/whatsapp
Social__Instagram=https://example.local/instagram
Social__Facebook=https://example.local/facebook
Social__DevLink=https://example.local/dev

# Image storage provider selection. Keep Local by default; set Minio to store product images in MinIO.
# Local single-stack default: root MinIO credentials, fine for `docker-compose.yml` dev use.
# If this file is copied to /opt/vaultshop/.env.compose for the shared platform deployment
# (docker-compose.store.yml), replace AccessKey/SecretKey with VAULTSHOP_MINIO_USER/PASSWORD
# from .platform.env instead — the app must never authenticate with MinIO root credentials
# in that deployment, since minio-init creates a bucket-scoped VaultShop user for it.
ImageStorage__Provider=Local
ImageStorage__Minio__Endpoint=minio:9000
ImageStorage__Minio__UseSsl=false
ImageStorage__Minio__BucketName=product-images
ImageStorage__Minio__AccessKey=minioadmin
ImageStorage__Minio__SecretKey=Change_this_MinIO_Password_123!
ImageStorage__Minio__PublicBaseUrl=http://localhost:9000/product-images
