# Copy to /opt/vaultshop/.platform.env and replace every placeholder.
# Do not commit the private file. It owns shared PostgreSQL and MinIO credentials.

DOCKER_RESTART_POLICY=unless-stopped

# Preserve these names when migrating the existing VaultShop single stack.
POSTGRES_VOLUME_NAME=vaultshop_postgres-data
MINIO_VOLUME_NAME=vaultshop_minio-data

POSTGRES_DB=vaultshop
POSTGRES_USER=vaultshop_app
POSTGRES_PASSWORD=Change_this_Postgres_Password_123!

# Created once by postgres-init. Existing roles are intentionally not modified.
UKIYO_POSTGRES_DATABASE=ukiyostudio
UKIYO_POSTGRES_USER=ukiyostudio_app
UKIYO_POSTGRES_PASSWORD=Replace_with_private_Ukiyo_Postgres_password

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=Change_this_MinIO_Password_123!

# minio-init creates one least-privilege user per store, scoped to only its
# own bucket (no ListAllMyBuckets, no other bucket's objects). The app never
# authenticates with MINIO_ROOT_USER/PASSWORD above; those are admin-only.
VAULTSHOP_MINIO_BUCKET=product-images
VAULTSHOP_MINIO_USER=vaultshop_app
VAULTSHOP_MINIO_PASSWORD=Replace_with_private_VaultShop_MinIO_password
UKIYO_MINIO_BUCKET=ukiyostudio-images
UKIYO_MINIO_USER=ukiyostudio_app
UKIYO_MINIO_PASSWORD=Replace_with_private_Ukiyo_MinIO_password
