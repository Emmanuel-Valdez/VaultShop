# Copy to a private ukiyo.env.compose file and replace every placeholder.
# Use with: docker compose --env-file /opt/ukiyostudio/.env.compose -f docker-compose.store.yml up -d
# Do not commit the private file or private brand assets.

APP_HTTP_BIND_IP=127.0.0.1
APP_HTTP_PORT=8081
APP_ASPNETCORE_ENVIRONMENT=Production
COMPOSE_PROJECT_NAME=ukiyostudio
DATABASE_RUN_MIGRATIONS_ON_STARTUP=false
DOCKER_RESTART_POLICY=unless-stopped

# Shared platform services resolve over vaultshop-net; neither service exposes a host port.
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=ukiyostudio;Username=ukiyostudio_app;Password=Replace_with_private_Postgres_password

# UkiyoStudio enables Mercado Pago and bank transfer. Stripe and Facebook stay disabled.
Stripe__SecretKey=
Stripe__PublishableKey=
Stripe__WebhookSecret=
Payments__BankTransferEnabled=true
Payments__StripeEnabled=false
Payments__MercadoPagoEnabled=true
Payments__MercadoPagoAccessToken=APP_USR-replace_with_private_mercado_pago_token
Payments__MercadoPagoWebhookSecret=replace_with_private_mercado_pago_webhook_secret
Payments__BankTransferCbu=replace_with_private_cbu
Payments__BankTransferAlias=replace_with_private_alias
Payments__BankTransferRecipientName=UkiyoStudio
Payments__BankTransferBankName=replace_with_private_bank_name
Facebook__AppId=
Facebook__AppSecret=

Email__Provider=Resend
Email__UseFakeEmailSender=false
Email__AdminEmail=replace_with_private_admin_email
Resend__ApiKey=re_replace_with_private_resend_key
Resend__FromEmail=replace_with_verified_sender_email
Seed__AdminEmail=replace_with_private_admin_email
Seed__AdminPassword=Replace_with_private_admin_password

SiteUrl=https://ukiyostudio.evaldez.ar
Branding__PublicName=UkiyoStudio
# Approved private assets are mounted read-only at /app/wwwroot/images/brand/private.
BrandAssetsPath=/opt/ukiyostudio/brand-assets
Branding__LogoPath=/images/brand/private/ukiyostudio-logo.svg
Branding__LogoDarkPath=/images/brand/private/ukiyostudio-logo-negative.svg
Branding__MarkPath=/images/brand/private/ukiyostudio-mark.png
Branding__AppleTouchIconPath=/images/brand/private/ukiyostudio-apple-touch-icon.png
Branding__SocialPreviewImagePath=/images/brand/private/ukiyostudio-social-preview.png
Branding__TwitterSite=
Storefront__ShowDemoNotice=false
DataProtection__KeysPath=/keys
DATA_PROTECTION_VOLUME_NAME=ukiyostudio_data-protection-keys

Theme__Primary=#3B2F3D
Theme__PrimaryDark=#2B222D
Theme__Accent=#D9A7B3
Theme__Surface=#F3E9E4
Theme__SurfaceDark=#2B222D

Social__TikTok=
Social__WhatsApp=
Social__Instagram=
Social__Facebook=
Social__DevLink=https://example.local/dev

ImageStorage__Provider=Minio
ImageStorage__Minio__Endpoint=minio:9000
ImageStorage__Minio__UseSsl=false
ImageStorage__Minio__BucketName=ukiyostudio-images
# Must match UKIYO_MINIO_USER / UKIYO_MINIO_PASSWORD in /opt/vaultshop/.platform.env.
# Never use the MinIO root credentials here; minio-init creates this scoped
# user with access to the ukiyostudio-images bucket only.
ImageStorage__Minio__AccessKey=ukiyostudio_app
ImageStorage__Minio__SecretKey=replace_with_private_ukiyo_minio_password
ImageStorage__Minio__PublicBaseUrl=https://ukiyostudio.evaldez.ar/product-images
