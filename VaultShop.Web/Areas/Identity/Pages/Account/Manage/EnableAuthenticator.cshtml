@page
@model EnableAuthenticatorModel
@{
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@Localizer["ConfigureAuthenticatorApp"]</h3>
<div>
    <p>@Localizer["FollowingSteps"]:</p>
    <ol class="list">
        <li>
            <p>
                @Localizer["MicrosoftAuthenticator"]
                <a href="https://go.microsoft.com/fwlink/?Linkid=825072">Android</a> @Localizer["And"] 
                <a href="https://go.microsoft.com/fwlink/?Linkid=825073">iOS</a> 
                @Localizer["OrGoogleAuthenticator"]
                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en">Android</a> @Localizer["And"] 
                <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">iOS</a>.
            </p>
        </li>
        <li>
            <p>@Localizer["ScanOrEnterKey"] <kbd>@Model.SharedKey</kbd> @Localizer["Into2FA"]. @Localizer["SpacesAndCasing"].</p>
            <div class="alert alert-info">@Localizer["LearHow"] <a href="https://go.microsoft.com/fwlink/?Linkid=852423">@Localizer["EnableQR"]</a>.</div>
            <div id="qrCode"></div>
            <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
        </li>
        <li>
            <p>
                @Localizer["ScanQR"] 
            </p>
            <div class="row">
                <div class="col-md-6">
                    <form id="send-code" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="Please enter the code."/>
							<label asp-for="Input.Code" class="control-label form-label">@Localizer["VerificationCode"]</label>
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>
                        <button type="submit" class="w-100 btn btn-lg btn-primary">@Localizer["Verify"]</button>
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
