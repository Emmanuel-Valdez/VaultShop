@model ShoppingCartVM
<form method="post" class="checkout-summary">
	@Html.AntiForgeryToken()
	<br />
	<div class="container">
		<div class="card shadow border-0 checkout-summary__card">

			<div class="card-header bg-secondary bg-gradient ml-0 py-4 border-0">
				<div class="row px-4 align-items-center g-3">
					<div class="col-12 col-md-7">
						<h1 class="h3 mb-0 text-primary">
							@Localizer["Title"]
						</h1>
					</div>
					<div class="col-12 col-md-5 text-md-end">
						<a asp-area="Customer" asp-Controller="Cart" asp-action="Index" class="btn btn-outline-primary btn-sm">@Localizer["BackToCart"]</a>
					</div>
				</div>
			</div>
			<div class="card-body p-4 p-lg-5">
				 <input asp-for="@Model.OrderHeader.ApplicationUserId" hidden />
				<div class="container-fluid rounded p-0">
					<div class="row g-4">
						<div class="col-12 col-lg-6 pb-4">
							<h2 class="h5 mb-3 text-primary">@Localizer["ShippingDetails"]</h2>
							<div class="form-floating mb-3">
								<input asp-for="OrderHeader.Name" class="form-control" placeholder=" " />
								<label asp-for="OrderHeader.Name">@Localizer["UserName"]</label>
								<span asp-validation-for="OrderHeader.Name" class="text-danger small"></span>
							</div>
							<div class="form-floating mb-3">
								<input asp-for="OrderHeader.PhoneNumber" class="form-control" placeholder=" " />
								<label asp-for="OrderHeader.PhoneNumber">@Localizer["UserPhoneNumber"]</label>
								<span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger small"></span>
							</div>
							<div class="form-floating mb-3">
								<input asp-for="OrderHeader.StreetAddress" class="form-control" placeholder=" " />
								<label asp-for="OrderHeader.StreetAddress">@Localizer["UserStreetAddress"]</label>
								<span asp-validation-for="OrderHeader.StreetAddress" class="text-danger small"></span>
							</div>
							<div class="row g-3">
								<div class="col-12 col-md-6">
									<div class="form-floating">
										<input asp-for="OrderHeader.City" class="form-control" placeholder=" " />
										<label asp-for="OrderHeader.City">@Localizer["UserCity"]</label>
										<span asp-validation-for="OrderHeader.City" class="text-danger small"></span>
									</div>
								</div>
								<div class="col-12 col-md-6">
									<div class="form-floating">
										<input asp-for="OrderHeader.State" class="form-control" placeholder=" " />
										<label asp-for="OrderHeader.State">@Localizer["UserState"]</label>
										<span asp-validation-for="OrderHeader.State" class="text-danger small"></span>
									</div>
								</div>
								<div class="col-12 col-md-6">
									<div class="form-floating">
										<input asp-for="OrderHeader.PostalCode" class="form-control" placeholder=" " />
										<label asp-for="OrderHeader.PostalCode">@Localizer["UserPostalCode"]</label>
										<span asp-validation-for="OrderHeader.PostalCode" class="text-danger small"></span>
									</div>
								</div>
							</div>
						</div>
						<div class="col-12 col-lg-5 offset-lg-1">
							<h2 class="h5 mb-3 text-primary">@Localizer["OrderSummary"]</h2>
							 <ul class="list-group mb-3 shadow-sm">
								@foreach (var details in Model.ShoppingCartList)
								{
									
									<li class="list-group-item d-flex justify-content-between">
										<div>
											<h6 class="my-0">@details.Product.Name</h6>
											<small class="text-muted">@Localizer["Quantity"]: @details.Count</small>
										</div>
										<span class="fw-semibold">@((details.Price * details.Count).ToString("c")) </span>
									</li>
								}

								<li class="list-group-item d-flex justify-content-between bg-secondary">
									<strong class="text-primary">@Localizer["Total"] </strong>
									<strong class="text-primary">@Model.OrderHeader.OrderTotal.ToString("C")</strong>
									
								</li>

							</ul>
						</div>
					</div>
					@{
						var stripeEnabled = ViewData["StripeEnabled"] is true;
						var bankTransferEnabled = ViewData["BankTransferEnabled"] is true;
						var bankTransferCbu = ViewData["BankTransferCbu"] as string ?? string.Empty;
						var bankTransferAlias = ViewData["BankTransferAlias"] as string ?? string.Empty;
						var bankTransferRecipientName = ViewData["BankTransferRecipientName"] as string ?? string.Empty;
						var bankTransferBankName = ViewData["BankTransferBankName"] as string ?? string.Empty;
					}
					<div class="row g-4 mt-2">
						<div class="col-12">
							<h2 class="h5 mb-3 text-primary">@Localizer["PaymentMethod"]</h2>
							@if (stripeEnabled && bankTransferEnabled)
							{
								<div class="form-check">
									<input class="form-check-input" type="radio" name="OrderHeader.PaymentMethod" id="paymentMethodStripe" value="Stripe" checked="checked" />
									<label class="form-check-label" for="paymentMethodStripe">@Localizer["PayWithStripe"]</label>
								</div>
								<div class="form-check">
									<input class="form-check-input" type="radio" name="OrderHeader.PaymentMethod" id="paymentMethodBankTransfer" value="BankTransfer" />
									<label class="form-check-label" for="paymentMethodBankTransfer">@Localizer["PayByBankTransfer"]</label>
								</div>
								<div id="bankTransferDetails" class="alert alert-info mt-2 d-none">
									<div><strong>@Localizer["BankTransferCbuLabel"]:</strong> @bankTransferCbu</div>
									@if (!string.IsNullOrWhiteSpace(bankTransferAlias))
									{
										<div><strong>@Localizer["BankTransferAliasLabel"]:</strong> @bankTransferAlias</div>
									}
									@if (!string.IsNullOrWhiteSpace(bankTransferRecipientName))
									{
										<div><strong>@Localizer["BankTransferRecipientNameLabel"]:</strong> @bankTransferRecipientName</div>
									}
									@if (!string.IsNullOrWhiteSpace(bankTransferBankName))
									{
										<div><strong>@Localizer["BankTransferBankNameLabel"]:</strong> @bankTransferBankName</div>
									}
								</div>
							}
							else if (bankTransferEnabled)
							{
								<input type="hidden" name="OrderHeader.PaymentMethod" value="BankTransfer" />
								<div class="alert alert-info">
									<div><strong>@Localizer["BankTransferCbuLabel"]:</strong> @bankTransferCbu</div>
									@if (!string.IsNullOrWhiteSpace(bankTransferAlias))
									{
										<div><strong>@Localizer["BankTransferAliasLabel"]:</strong> @bankTransferAlias</div>
									}
									@if (!string.IsNullOrWhiteSpace(bankTransferRecipientName))
									{
										<div><strong>@Localizer["BankTransferRecipientNameLabel"]:</strong> @bankTransferRecipientName</div>
									}
									@if (!string.IsNullOrWhiteSpace(bankTransferBankName))
									{
										<div><strong>@Localizer["BankTransferBankNameLabel"]:</strong> @bankTransferBankName</div>
									}
								</div>
							}
							else
							{
								<input type="hidden" name="OrderHeader.PaymentMethod" value="Stripe" />
							}
						</div>
					</div>
				</div>
			</div>
			<div class="card-footer bg-white border-0 p-4 p-lg-5 pt-0">
				<div class="row align-items-center g-3">
					<div class="col-12 mb-3">
						<div class="checkout-demo-notice" role="alert">
							<div class="checkout-demo-notice__icon" aria-hidden="true">
								<i class="bi bi-shield-exclamation"></i>
							</div>
							<div>
								<strong>@Localizer["StripeTestModeTitle"]</strong>
								<div>@Localizer["StripeTestModeMessage"]</div>
							</div>
						</div>
					</div>
					<div class="col-12 col-md-8 pt-2">
						<p class="text-muted small mb-0">
							@Localizer["EstimateArrivalDate"] :
							@DateTime.Now.AddDays(7).ToShortDateString() - @DateTime.Now.AddDays(14).ToShortDateString()

						</p>
					</div>
					<div class="col-12 col-md-4">
						<button type="submit" value="Place Order" class="btn btn-primary form-control @(Model.OrderHeader.OrderTotal == 0 ? "disabled" : "")"> 
							@Localizer["PlaceOrder"]
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
</form>

@section Scripts {
	@{
		<partial name="_ValidationScriptsPartial" />
	}
	<script>
		(function () {
			var bankTransferRadio = document.getElementById('paymentMethodBankTransfer');
			var stripeRadio = document.getElementById('paymentMethodStripe');
			var details = document.getElementById('bankTransferDetails');
			if (!bankTransferRadio || !details) { return; }
			function toggle() { details.classList.toggle('d-none', !bankTransferRadio.checked); }
			bankTransferRadio.addEventListener('change', toggle);
			if (stripeRadio) { stripeRadio.addEventListener('change', toggle); }
			toggle();
		})();
	</script>
}


