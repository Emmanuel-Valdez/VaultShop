@{
    ViewData["Title"] = Localizer["FAQs"];
    ViewData["Description"] = Localizer["MetaDescription"];
    ViewData["Keywords"] = Localizer["MetaKeywords"];
}

<div class="container my-5">
    <h1 class="text-center mb-4">@Localizer["FAQs"]</h1>
    <div class="accordion" id="accordionFAQs">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                    @Localizer["Question1"]
                </button>
            </h2>
            <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#accordionFAQs">
                <div class="accordion-body">
                    <strong>@Localizer["Answer1"]</strong>
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                    @Localizer["Question2"]
                </button>
            </h2>
            <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#accordionFAQs">
                <div class="accordion-body">
                    <strong>@Localizer["Answer2"]</strong>
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                    @Localizer["Question3"]
                </button>
            </h2>
            <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#accordionFAQs">
                <div class="accordion-body">
                    <ul>
                        <li>@Localizer["Answer3Item1"]</li>
                        <li>@Localizer["Answer3Item2"]</li>
                        <li>@Localizer["Answer3Item3"]</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
                    @Localizer["Question4"]
                </button>
            </h2>
            <div id="collapseFour" class="accordion-collapse collapse" data-bs-parent="#accordionFAQs">
                <div class="accordion-body">
                    <strong>@Localizer["Answer4Intro"]</strong>
                    <ul>
                        <li>@Localizer["Answer4Item1"]</li>
                        <li>@Localizer["Answer4Item2"]</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFive" aria-expanded="false" aria-controls="collapseFive">
                    @Localizer["Question5"]
                </button>
            </h2>
            <div id="collapseFive" class="accordion-collapse collapse" data-bs-parent="#accordionFAQs">
                <div class="accordion-body">
                    <strong>@Localizer["Answer5Prefix"]</strong> @Localizer["Answer5Suffix"]
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSix" aria-expanded="false" aria-controls="collapseSix">
                    @Localizer["Question6"]
                </button>
            </h2>
            <div id="collapseSix" class="accordion-collapse collapse" data-bs-parent="#accordionFAQs">
                <div class="accordion-body">
                    <strong>@Localizer["Answer6Intro"]</strong>
                    <ul>
                        <li>@Localizer["Answer6Item1"]</li>
                        <li>@Localizer["Answer6Item2"]</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSeven" aria-expanded="false" aria-controls="collapseSeven">
                    @Localizer["Question7"]
                </button>
            </h2>
            <div id="collapseSeven" class="accordion-collapse collapse" data-bs-parent="#accordionFAQs">
                <div class="accordion-body">
                    @Localizer["Answer7Prefix"] <strong>@Localizer["Answer7Strong"]</strong> @Localizer["Answer7Suffix"]
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEight" aria-expanded="false" aria-controls="collapseEight">
                    @Localizer["Question8"]
                </button>
            </h2>
            <div id="collapseEight" class="accordion-collapse collapse" data-bs-parent="#accordionFAQs">
                <div class="accordion-body">
                    <strong>@Localizer["Answer8Intro"]</strong>
                    <ul>
                        <li>@Localizer["Answer8Item1"]</li>
                        <li>@Localizer["Answer8Item2"]</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseNine" aria-expanded="false" aria-controls="collapseNine">
                    @Localizer["Question9"]
                </button>
            </h2>
            <div id="collapseNine" class="accordion-collapse collapse" data-bs-parent="#accordionFAQs">
                <div class="accordion-body">
                    @Localizer["Answer9"]
                </div>
            </div>
        </div>
    </div>
</div>
