@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using UkiyoDesignsWeb.Services.Branding
@model ShoppingCart
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IOptions<BrandingOptions> BrandingOptionsAccessor

@{
    var branding = BrandingOptionsAccessor.Value;
    ViewData["Title"] = Model.Product.Name;
    ViewData["Description"] = Model.Product.Description?.Length > 150 ? Model.Product.Description.Substring(0, 150) + "..." : Model.Product.Description ?? string.Format(Localizer["ProductFallbackDescription"].Value, Model.Product.Name);
    ViewData["Keywords"] = $"{Model.Product.Name}, {Model.Product.Category.Name}, {Localizer["MetaKeywordsSuffix"].Value}";
    var productImages = Model.Product.ProductImages.OrderedForDisplay().ToList();
    var imageUrl = productImages.FirstOrDefault()?.ImageUrl ?? $"{SD.SiteUrl}{branding.SocialPreviewImagePath}";
    ViewData["OgImage"] = imageUrl;
}

<script type="application/ld+json">
{
    "@( "@" )context": "https://schema.org",
    "@( "@" )type": "Product",
    "name": "@Model.Product.Name",
    "description": "@Html.Raw(Model.Product.Description?.Replace("\"", "'"))",
    "image": "@imageUrl",
    "offers": {
        "@( "@" )type": "Offer",
        "priceCurrency": "ARS",
        "price": "@Model.Product.FinalRetailPrice.ToString("F2")",
        "availability": "https://schema.org/InStock"
    },
    "brand": {
        "@( "@" )type": "Brand",
        "name": "@branding.PublicName"
    }
}
</script>

<form method="post">
	@Html.AntiForgeryToken()

	<div class="product-detail card shadow-sm border-0 mt-4 mb-4 bg-secondary">
		<input asp-for="@Model.ApplicationUserId" hidden />
		<input asp-for="@Model.ProductId" hidden />
		<div class="card-body p-3 p-lg-4">
			<a asp-action="Index" class="btn btn-outline-primary bg-gradient fw-semibold btn-sm text-uppercase mb-4">
				<small>@Localizer["BackToHome"]</small>
			</a>
			<div class="row g-4 g-xl-5 align-items-start">
				<div class="col-12 col-lg-6">
					<div class="product-detail__media rounded-3">
						@if (productImages.Count > 0)
						{
							<div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="carousel">
								@if (productImages.Count > 1)
								{
									<div class="carousel-indicators">
										@foreach (var imageWithIndex in productImages.Select((image, index) => new { Image = image, Index = index }))
										{
											<button type="button" data-bs-target="#carouselExampleIndicators"
													data-bs-slide-to="@imageWithIndex.Index" class="@(imageWithIndex.Index == 0 ? "active" : "")" aria-current="@(imageWithIndex.Index == 0 ? "true" : null)" aria-label="@Localizer["ProductImage", imageWithIndex.Index + 1]"></button>
										}
									</div>
								}
								<div class="carousel-inner">
									@foreach (var imageWithIndex in productImages.Select((image, index) => new { Image = image, Index = index }))
									{
										<div class="carousel-item @(imageWithIndex.Index == 0 ? "active" : "")">
											<img src="@imageWithIndex.Image.ImageUrl" class="product-detail__image" alt="@Model.Product.Name">
										</div>
									}
								</div>
								@if (productImages.Count > 1)
								{
									<button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
										<span class="carousel-control-prev-icon" aria-hidden="true"></span>
										<span class="visually-hidden">Previous</span>
									</button>
									<button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
										<span class="carousel-control-next-icon" aria-hidden="true"></span>
										<span class="visually-hidden">Next</span>
									</button>
								}
							</div>
						}
						else
						{
							<img src="https://placehold.co/500x600/png" class="product-detail__image" alt="@Model.Product.Name" />
						}
					</div>
				</div>
				<div class="col-12 col-lg-6">
					<section class="product-detail__panel h-100" aria-labelledby="product-title">
						@if (!string.IsNullOrWhiteSpace(Model.Product.Category?.Name))
						{
							<span class="product-detail__badge badge rounded-pill mb-3">@Model.Product.Category.Name</span>
						}
						<h1 id="product-title" class="display-6 text-primary fw-semibold mb-2">@Model.Product.Name</h1>
						<p class="product-card__meta mb-4">@Localizer["InspiredBy"]</p>

						<div class="mb-4">
							<div class="product-card__meta mb-1">@Localizer["Price"]</div>
							@if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee) || User.IsInRole(SD.Role_Company))
							{
								<div class="h4 text-warning mb-1">
									<span class="text-decoration-line-through">@Model.Product.FinalRetailPrice.ToString("c")</span>
								</div>
								<div class="product-detail__price text-success">@Model.Product.FinalWholesalePrice.ToString("c")</div>
							}
							else
							{
								<div class="product-detail__price text-success">@Model.Product.FinalRetailPrice.ToString("c")</div>
							}
						</div>

						<div class="product-detail__description mb-4">
							@Html.Raw(Model.Product.Description)
						</div>

						<div class="row g-3 align-items-end">
							<div class="col-12 col-sm-4 product-detail__quantity">
								<label asp-for="Count" class="form-label fw-semibold">@Localizer["Count"]</label>
								<input asp-for="Count" type="number" value="1" class="form-control text-end product-detail__quantity-input" />
								<span asp-validation-for="Count" class="text-danger product-detail__quantity-validation"></span>
							</div>
							<div class="col-12 col-sm-8 product-detail__actions">
								<div class="d-flex gap-2">
									@if ((User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee) || User.IsInRole(SD.Role_Company)) && Model.Product.FinalWholesalePrice == 0)
									{
										<button class="btn btn-danger disabled bg-gradient py-2 text-uppercase fw-semibold flex-grow-1">
											@Localizer["TemporarilyUnavailable"]
										</button>
									}
									else
									{
										<button type="submit" class="btn btn-primary bg-gradient py-2 text-uppercase fw-semibold flex-grow-1">
											@Localizer["AddToCart"]
										</button>
									}
									@if (SignInManager.IsSignedIn(User))
									{
										@if (Model.IsFavorite == false)
										{
											<button type="submit" class="btn btn-outline-primary fs-4 px-3" asp-action="Add" asp-controller="Favorite" aria-label="@Localizer["AddToFavorites"]">
												<i class="bi bi-balloon-heart"></i>
											</button>
										}
										else
										{
											<button type="submit" class="btn btn-outline-primary fs-4 px-3" asp-action="RemoveFromProductDetails" asp-controller="Favorite" asp-route-favoriteId="@Model.FavoriteProductId" asp-route-productId="@Model.ProductId" aria-label="@Localizer["RemoveFromFavorites"]">
												<i class="bi bi-balloon-heart-fill"></i>
											</button>
										}
									}
								</div>
							</div>
						</div>
					</section>
				</div>
			</div>
		</div>
	</div>
</form>
@section Scripts {
	@{
		<partial name="_ValidationScriptsPartial" />
	}
}

