@{
    ViewData["Title"] = Localizer["Wholesale"];
    ViewData["Description"] = Localizer["MetaDescription"];
    ViewData["Keywords"] = Localizer["MetaKeywords"];
}

<div class="container my-5">
    <h1 class="text-center mb-4">@Localizer["Wholesale"]</h1>
    <div class="mt-4">
        <p>@Localizer["IntroPrefix"] <strong>VaultShop</strong>, @Localizer["IntroSuffix"]</p>
        <ul>
            <li><strong>@Localizer["PaymentMethodLabel"]:</strong> @Localizer["PaymentMethodText"]</li>
            <li><strong>@Localizer["ClearPricesLabel"]:</strong> @Localizer["ClearPricesText"]</li>
            <li><strong>@Localizer["FirstOrderLabel"]:</strong> @Localizer["FirstOrderText"]</li>
            <li><strong>@Localizer["PaymentDeadlineLabel"]:</strong> @Localizer["PaymentDeadlineText"]</li>
            <li><strong>@Localizer["DispatchTimesLabel"]:</strong> @Localizer["DispatchTimesText"]</li>
            <li>@Localizer["ContactText"]</li>
        </ul>
    </div>
</div>
