@model OrderVM
@{
	var canManageOrder = User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee);
	var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
	var orderIsTerminal = Model.OrderHeader.OrderStatus == SD.StatusCancelled ||
		Model.OrderHeader.OrderStatus == SD.StatusRefunded ||
		Model.OrderHeader.PaymentStatus == SD.PaymentStatusRejected;
	var canEditShippingDetails = User.IsInRole(SD.Role_Admin) && !orderIsTerminal;
	var canEditFulfillmentDetails = canManageOrder && !orderIsTerminal;
	var allowDevelopmentManualApproval = ViewData["AllowDevelopmentManualPaymentApproval"] is true;
	var paymentCanBeManuallyApproved = Model.OrderHeader.PaymentStatus == SD.PaymentStatusPending ||
		Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment;
	var paymentNeedsApproval = Model.OrderHeader.PaymentStatus == SD.PaymentStatusPending ||
		Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment;
	var isCompanyDelayedPayment = Model.OrderHeader.CompanyId.GetValueOrDefault() > 0 &&
		Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment;
	var canStartProcessing = Model.OrderHeader.OrderStatus == SD.StatusApproved &&
		(Model.OrderHeader.PaymentStatus == SD.PaymentStatusApproved || isCompanyDelayedPayment);
	var canShipOrder = Model.OrderHeader.OrderStatus == SD.StatusInProcess &&
		Model.OrderHeader.PaymentStatus == SD.PaymentStatusApproved &&
		!orderIsTerminal;
	var shippingBlockedUntilPaymentApproved = canManageOrder &&
		Model.OrderHeader.OrderStatus == SD.StatusInProcess &&
		Model.OrderHeader.PaymentStatus != SD.PaymentStatusApproved &&
		!orderIsTerminal;
	var canManuallyApprovePayment = allowDevelopmentManualApproval && canEditShippingDetails &&
		!string.IsNullOrWhiteSpace(Model.OrderHeader.SessionId) && paymentCanBeManuallyApproved && !orderIsTerminal;
	var canPayNow = User.IsInRole(SD.Role_Company) &&
		Model.OrderHeader.CompanyId.GetValueOrDefault() > 0 &&
		Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment &&
		!orderIsTerminal;
	var canConfirmBankTransfer = canEditShippingDetails && !orderIsTerminal &&
		Model.OrderHeader.PaymentMethod == SD.PaymentMethodBankTransfer &&
		Model.OrderHeader.PaymentStatus == SD.PaymentStatusPending;
	var bankTransferCbu = ViewData["BankTransferCbu"] as string ?? string.Empty;
	var bankTransferAlias = ViewData["BankTransferAlias"] as string ?? string.Empty;
	var bankTransferRecipientName = ViewData["BankTransferRecipientName"] as string ?? string.Empty;
	var bankTransferBankName = ViewData["BankTransferBankName"] as string ?? string.Empty;
	var transferAlreadyConfirmed = Model.OrderHeader.TransferConfirmedByCustomerAt.HasValue;
	var showBankTransferInstructions = Model.OrderHeader.PaymentMethod == SD.PaymentMethodBankTransfer &&
		(Model.OrderHeader.PaymentStatus == SD.PaymentStatusPending || Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment) &&
		!transferAlreadyConfirmed;
	var canCustomerConfirmTransfer = !canManageOrder &&
		Model.OrderHeader.PaymentMethod == SD.PaymentMethodBankTransfer &&
		(Model.OrderHeader.PaymentStatus == SD.PaymentStatusPending || Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment) &&
		!transferAlreadyConfirmed &&
		!string.IsNullOrEmpty(currentUserId) &&
		Model.OrderHeader.ApplicationUserId == currentUserId &&
		Model.OrderHeader.CompanyId.GetValueOrDefault() == 0;

	string StatusBadgeClass(string? status) => status switch
	{
		SD.StatusCancelled or SD.StatusRefunded or SD.PaymentStatusRejected => "bg-danger",
		SD.StatusPending or SD.PaymentStatusDelayedPayment => "bg-warning text-dark",
		SD.StatusInProcess => "bg-info text-dark",
		SD.StatusApproved or SD.StatusShipped or SD.PaymentStatusApproved => "bg-success",
		_ => "bg-secondary"
	};
}

<form method="post">
	@Html.AntiForgeryToken()
	<br />
	<input asp-for="OrderHeader.Id" hidden type="text" />
	<input asp-for="OrderHeader.ApplicationUserId" type="text" hidden />
	<div class="container">
		<div class="card">
			<div class="card-header bg-dark text-light ml-0">
				<div class="container row">
					<div class="col-12 d-md-block col-md-6 pb-1">
						<i class="bi bi-cart3"></i> &nbsp; @Localizer["OrderSummary"]
					</div>
					<div class="col-12 col-md-4 offset-md-2 text-right">
						<a asp-action="Index" class="btn btn-outline-info form-control btn-sm">@Localizer["BackToOrders"]</a>
					</div>
				</div>
			</div>
			<div class="card-body">
				<div class="container rounded p-2">
					<div class="row">
						<div class="col-12 col-lg-6 pb-4">
							<div class="row">
								<h4 class="d-flex justify-content-between align-items-center mb-3">
									<span class="text-primary">@Localizer["PickupDetails"]:</span>
								</h4>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["Name"]</div>
								<div class="col-9 ">
									@if (canEditShippingDetails)
									{
										<input asp-for="OrderHeader.Name" type="text" class="form-control shadow" />
										<span asp-validation-for="OrderHeader.Name" class="text-danger"></span>
									}
									else
									{
										<input asp-for="OrderHeader.Name" readonly type="text" class="form-control shadow" />
									}

								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["Phone"]</div>
								<div class="col-9 ">
									@if (canEditShippingDetails)
									{
										<input asp-for="OrderHeader.PhoneNumber" type="text" class="form-control shadow " />
										<span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
									}
									else
									{
										<input asp-for="OrderHeader.PhoneNumber" readonly type="text" class="form-control shadow" />
									}
								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["Address"]</div>
								<div class="col-9">
									@if (canEditShippingDetails)
									{
										<input asp-for="OrderHeader.StreetAddress" type="text" class="form-control shadow" />
										<span asp-validation-for="OrderHeader.StreetAddress" class="text-danger"></span>
									}
									else
									{
										<input asp-for="OrderHeader.StreetAddress" readonly type="text" class="form-control shadow" />
									}
								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["City"]</div>
								<div class="col-9">
									@if (canEditShippingDetails)
									{
										<input asp-for="OrderHeader.City" type="text" class="form-control shadow" />
										<span asp-validation-for="OrderHeader.City" class="text-danger"></span>
									}
									else
									{
										<input asp-for="OrderHeader.City" readonly type="text" class="form-control shadow" />
									}
								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["State"]</div>
								<div class="col-9">
									@if (canEditShippingDetails)
									{
										<input asp-for="OrderHeader.State" type="text" class="form-control shadow" />
										<span asp-validation-for="OrderHeader.State" class="text-danger"></span>
									}
									else
									{
										<input asp-for="OrderHeader.State" readonly type="text" class="form-control shadow" />
									}
								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["ZipCode"]</div>
								<div class="col-9">
									@if (canEditShippingDetails)
									{
										<input asp-for="OrderHeader.PostalCode" type="text" class="form-control shadow" />
										<span asp-validation-for="OrderHeader.PostalCode" class="text-danger"></span>
									}
									else
									{
										<input asp-for="OrderHeader.PostalCode" readonly type="text" class="form-control shadow" />
									}
								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["Email"]</div>
								<div class="col-9">
									<input asp-for="OrderHeader.ApplicationUser.Email" readonly type="text" class="form-control shadow" />
								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["OrderDate"]</div>
								<div class="col-9">

									<input value="@Model.OrderHeader.OrderDate.ToShortDateString()" readonly type="text" class="form-control shadow" />

								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["Carrier"]</div>
								<div class="col-9">
									@if (canEditFulfillmentDetails)
									{
										<input asp-for="OrderHeader.Carrier" id="carrier" type="text" class="form-control shadow" />
									}
									else
									{
										<input asp-for="OrderHeader.Carrier" readonly type="text" class="form-control shadow" />
									}
								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["Tracking"]</div>
								<div class="col-9">
									@if (canEditFulfillmentDetails)
									{
										<input asp-for="OrderHeader.TrackingNumber" id="trackingNumber" type="text" class="form-control shadow" />
									}
									else
									{
										<input asp-for="OrderHeader.TrackingNumber" readonly type="text" class="form-control shadow" />
									}
								</div>
							</div>
							<div class="row my-1">
								<div class="col-3">@Localizer["ShippingDate"]</div>
								<div class="col-9">
									<input value="@Model.OrderHeader.ShippingDate.ToShortDateString()" readonly type="text" class="form-control shadow" />
								</div>
							</div>
							@if (canManageOrder)
							{
								<div class="row my-1">
									<div class="col-3">@Localizer["SessionId"]</div>
									<div class="col-9">
										<input asp-for="OrderHeader.SessionId" readonly type="text" class="form-control shadow" />
									</div>
								</div>
								<div class="row my-1">
									<div class="col-3">@Localizer["PaymentIntentId"]</div>
									<div class="col-9">
										<input asp-for="OrderHeader.PaymentIntentId" readonly type="text" class="form-control shadow" />
									</div>
								</div>
							}
							@if (Model.OrderHeader.PaymentStatus == SD.PaymentStatusApproved)
							{
								<div class="row my-1">
									<div class="col-3">@Localizer["PaymentDate"]</div>
									<div class="col-9">
										<input value="@(Model.OrderHeader.PaymentDate == default ? string.Empty : Model.OrderHeader.PaymentDate.ToShortDateString())" readonly type="text" class="form-control shadow" />
									</div>
								</div>
							}
							else if (Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment)
							{
								<div class="row my-1">
									<div class="col-3">@Localizer["PaymentDueDate"]</div>
									<div class="col-9">
										<input value="@(Model.OrderHeader.PaymentDueDate == default ? string.Empty : Model.OrderHeader.PaymentDueDate.ToShortDateString())" readonly type="text" class="form-control shadow" />
									</div>
								</div>
							}
							<div class="row my-1">
								<div class="col-3">@Localizer["PaymentStatus"]</div>
								<div class="col-9">
									<input asp-for="OrderHeader.PaymentStatus" readonly type="text" class="form-control shadow" id="paymentStatusInput"
										   data-localizer-key="PaymentStatus" />
								</div>
							</div>
							@if (canEditFulfillmentDetails)
							{
								<Button type="submit" asp-action="UpdateOrderDetail" class="btn btn-warning form-control my-1">
									@Localizer["UpdateOrderDetails"]
								</Button>
							}
						</div>
						<div class="col-12 col-lg-5 offset-lg-1">
							<h4 class="d-flex justify-content-between align-items-center mb-3">
								<span class="text-primary">@Localizer["OrderSummary"]</span>
							</h4>

							<div class="border rounded p-2 my-2">
								<div class="d-flex justify-content-between gap-2">
									<span>@Localizer["OrderStatus"]</span>
									<span class="badge @StatusBadgeClass(Model.OrderHeader.OrderStatus)">@Localizer[Model.OrderHeader.OrderStatus ?? string.Empty]</span>
								</div>
								<div class="d-flex justify-content-between gap-2 mt-1">
									<span>@Localizer["PaymentStatus"]</span>
									<span class="badge @StatusBadgeClass(Model.OrderHeader.PaymentStatus)">@Localizer[Model.OrderHeader.PaymentStatus ?? string.Empty]</span>
								</div>
							</div>
							@if (orderIsTerminal)
							{
								<div class="alert alert-danger my-2" role="alert">@Localizer["TerminalOrderReadOnlyMessage"]</div>
							}
							@if (paymentNeedsApproval)
							{
								<div class="alert alert-warning my-2" role="alert">@Localizer["PaymentNotApprovedMessage"]</div>
							}
							@if (shippingBlockedUntilPaymentApproved)
							{
								<div class="alert alert-warning my-2" role="alert">@Localizer["ShippingBlockedUntilPaymentApprovedMessage"]</div>
							}
							@if (showBankTransferInstructions)
							{
								<div class="alert alert-info my-2" role="alert">
									<div><strong>@Localizer["BankTransferCbuLabel"]:</strong> @bankTransferCbu</div>
									@if (!string.IsNullOrWhiteSpace(bankTransferAlias))
									{
										<div><strong>@Localizer["BankTransferAliasLabel"]:</strong> @bankTransferAlias</div>
									}
									@if (!string.IsNullOrWhiteSpace(bankTransferRecipientName))
									{
										<div><strong>@Localizer["BankTransferRecipientNameLabel"]:</strong> @bankTransferRecipientName</div>
									}
									@if (!string.IsNullOrWhiteSpace(bankTransferBankName))
									{
										<div><strong>@Localizer["BankTransferBankNameLabel"]:</strong> @bankTransferBankName</div>
									}
								</div>
							}
							else if (Model.OrderHeader.PaymentMethod == SD.PaymentMethodBankTransfer && transferAlreadyConfirmed)
							{
								<div class="alert alert-secondary my-2" role="alert">@Localizer["BankTransferAlreadyReportedMessage"]</div>
							}

							<ul class="list-group mb-3">
								@foreach (var detail in Model.OrderDetail)
								{
									<li class="list-group-item d-flex justify-content-between p-2">
										<div class="row container">
											<div class="col-8">

												<h6 class="my-0 text-primary">@detail.Product.Name</h6>
												<small class="text-muted">@Localizer["Price"] : @detail.Price.ToString("c")</small><br />
												<small class="text-muted">@Localizer["Quantity"] : @detail.Count</small>
											</div>
											<div class="col-4 text-end">
												<p class="text-success">@((detail.Count * detail.Price).ToString("c"))</p>
											</div>
										</div>
									</li>
								}
								<li class="list-group-item bg-primary">
									<div class="row container">
										<div class="col-6">
											<h5 class="text-white">@Localizer["Total"] </h5>
										</div>
										<div class="col-6 text-end">
											<h5 class="text-white">@Model.OrderHeader.OrderTotal.ToString("c")</h5>
										</div>
									</div>
								</li>
							</ul>
							@if (canPayNow)
							{
								<button type="submit" class="btn btn-success form-control my-1">@Localizer["PayNow"]</button>
							}
							@if (canCustomerConfirmTransfer)
							{
								<button type="submit" asp-action="ConfirmTransferSent" asp-route-orderId="@Model.OrderHeader.Id" class="btn btn-outline-primary form-control my-1">
									@Localizer["ConfirmTransferSent"]
								</button>
							}
							@if (canManageOrder)
							{
								if (canConfirmBankTransfer)
								{
									<button type="submit" asp-action="ConfirmBankTransfer" class="btn btn-success form-control my-1">
										@Localizer["ConfirmBankTransferReceived"]
									</button>
								}
								if (canManuallyApprovePayment)
								{
									<div class="alert alert-warning my-2">
										Development only: manually approves this order as paid. Do not use in preview or production.
									</div>
									<button type="submit" asp-action="ApprovePaymentDevelopment" class="btn btn-outline-warning form-control my-1">Development only: approve payment manually</button>
								}
								if (canStartProcessing)
								{
									<button type="submit" asp-action="StartProcessing" class="btn btn-primary form-control my-1">
										@Localizer["StartProcessing"]
									</button>
								}
								if (canShipOrder)
								{
									<button type="submit" asp-action="ShipOrder" onClick="return validateImput()" class="btn btn-primary form-control my-1">
										@Localizer["ShipOrder"]
									</button>
								}
								if (User.IsInRole(SD.Role_Admin) &&
													!orderIsTerminal &&
													Model.OrderHeader.OrderStatus != SD.StatusRefunded &&
													Model.OrderHeader.OrderStatus != SD.StatusCancelled &&
													Model.OrderHeader.OrderStatus != SD.StatusShipped)
								{
									<button type="submit" asp-action="CancelOrder" onclick="return confirmCancelOrder(event)" class="btn btn-danger form-control my-1">
										@Localizer["CancelOrder"]
									</button>
								}
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</form>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script>
		function validateImput() {
			if (document.getElementById("carrier").value == "") {
				Swal.fire({
					icon: 'error',
					title: '@Localizer["ShippingValidationTitle"]',
					text: '@Localizer["CarrierRequired"]'
				});
				return false;
			}
			if (document.getElementById("trackingNumber").value == "") {
				Swal.fire({
					icon: 'error',
					title: '@Localizer["ShippingValidationTitle"]',
					text: '@Localizer["TrackingRequired"]',
				});
				return false;
			}
			return true;
		}

		function confirmCancelOrder(event) {
			const button = event.currentTarget;
			if (button.dataset.confirmed === "true") {
				return true;
			}

			event.preventDefault();
			Swal.fire({
				icon: 'warning',
				title: @Json.Serialize(Localizer["CancelOrderConfirmTitle"].Value),
				text: @Json.Serialize(Localizer["CancelOrderConfirmText"].Value),
				showCancelButton: true,
				confirmButtonText: @Json.Serialize(Localizer["CancelOrderConfirmButton"].Value),
				cancelButtonText: @Json.Serialize(Localizer["CancelOrderKeepButton"].Value),
				confirmButtonColor: '#dc3545',
				focusCancel: true
			}).then((result) => {
				if (result.isConfirmed) {
					button.dataset.confirmed = "true";
					button.click();
				}
			});

			return false;
		}

		document.addEventListener("DOMContentLoaded", function () {
			// Referencia al input
			const paymentStatusInput = document.getElementById("paymentStatusInput");

			// Valor actual
			const statusValue = paymentStatusInput.value;

			// Diccionario de traducción
			const translations = {
				"Pending": "@Localizer["Pending"]",
				"Approved": "@Localizer["Approved"]",
				"ApprovedForDelayedPayment": "@Localizer["ApprovedForDelayedPayment"]",
				"Rejected": "@Localizer["Rejected"]",
				"Refunded": "@Localizer["Refunded"]",
				"Cancelled": "@Localizer["Cancelled"]",
			};

			// Traducción del valor
			if (translations[statusValue]) {
				paymentStatusInput.value = translations[statusValue];
			}
		});


	</script>


}
