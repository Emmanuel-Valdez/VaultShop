@model Company

<div class="card shadow border-0 my-4">
	<div class="card-header bg-primary bg-gradient ml-0 py-3">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-secondary"> @(Model.Id != 0 ? Localizer["Update"] : Localizer["Create"]) @Localizer["Company"]</h2>
			</div>
		</div>
	</div>
	<div class="card-body p-4">

		<form method="post">
			@Html.AntiForgeryToken()
			<input asp-for="Id" hidden />
			<div class="border p-3 ">
				<div asp-validation-summary="ModelOnly" class="text-danger"></div>
				<div class="mb-3">
					<div class="form-floating mb-3 col-md-12 shadow">
						<input asp-for="Name" class="form-control" placeholder="Name" />
						<label asp-for="Name" class="ms-2 text-muted">@Localizer["Name"]</label>
					</div>
					<span asp-validation-for="Name" class="text-danger"></span>
				</div>
				<div class="mb-3">
					<div class="form-floating mb-3 col-md-12 shadow">
						<input asp-for="StreetAddress" class="form-control" placeholder="StreetAddress" />
						<label asp-for="StreetAddress" class="ms-2 text-muted">@Localizer["StreetAddress"]</label>
					</div>					
				</div>
				<div class="mb-3">
					<div class="form-floating mb-3 col-md-12 shadow">
						<input asp-for="City" class="form-control" placeholder="City" />
						<label asp-for="City" class="ms-2 text-muted">@Localizer["City"]</label>
					</div>				
				</div>
				<div class="mb-3">
					<div class="form-floating mb-3 col-md-12 shadow">
						<input asp-for="State" class="form-control" placeholder="State" />
						<label asp-for="State" class="ms-2 text-muted">@Localizer["State"]</label>
					</div>					
				</div>
				<div class="mb-3">
					<div class="form-floating mb-3 col-md-12 shadow">
						<input asp-for="PostalCode" class="form-control" placeholder="PostalCode" />
						<label asp-for="PostalCode" class="ms-2 text-muted">@Localizer["PostalCode"]</label>
					</div>
				</div>
				<div class="mb-3">
					<div class="form-floating mb-3 col-md-12 shadow">
						<input asp-for="PhoneNumber" class="form-control" placeholder="PhoneNumber" />
						<label asp-for="PhoneNumber" class="ms-2 text-muted">@Localizer["PhoneNumber"]</label>
					</div>
				</div>
				<div class="row mt-3">
					<div class="col-6 col-md-3">
						@if (Model.Id != 0)
						{
							<button type="submit" class="btn btn-primary form-control">@Localizer["Update"]</button>
						}
						else
						{
							<button type="submit" class="btn btn-primary form-control">@Localizer["Create"]</button>
						}
					</div>
					<div class="col-6 col-md-3">
						<a asp-controller="Company" asp-action="Index" class="btn btn-outline-primary border form-control">
							@Localizer["BackToList"]
						</a>
					</div>
				</div>
			</div>
		</form>
	</div>
</div>


@section Scripts {
	@{
		<partial name="_ValidationScriptsPartial" />
	}
}
