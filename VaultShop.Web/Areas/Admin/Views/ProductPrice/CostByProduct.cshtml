
<div class="card shadow border-0 my-4">
	<div class="card-header bg-primary bg-gradient ml-0 py-3">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-secondary">@Localizer["CostsByProduct"]</h2>
			</div>
		</div>
	</div>
	<div class="card-body p-4">

		<table id="tblData" class="table table-bordered table-striped">
			<thead>
				<tr>
					<th>@Localizer["ProductName"]</th>
					<th>@Localizer["Category"]</th>
					<th>@Localizer["MaxExpectationMonthly"] </th>
					<th>@Localizer["FixedCostAdded"]</th>
					<th>@Localizer["Packaging"]</th>
					<th>@Localizer["GarmentHardware"]</th>
					<th>@Localizer["Fabric"]</th>
					<th>@Localizer["Total"]</th>
				</tr>
			</thead>
		</table>
	</div>
</div>
@section Scripts {
	<script src="~/js/costByProduct.js"></script>
}
