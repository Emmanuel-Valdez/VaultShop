
<div class="card shadow border-0 my-4">
	<div class="card-header bg-primary bg-gradient ml-0 py-3">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-secondary text-center">@Localizer["UserList"]</h2>
			</div>
		</div>
	</div>
	<div class="card-body p-4">
		<table id="tblData" class="table table-bordered table-striped table-hover" style="width:100%">
			<thead>
				<tr>
				
					<th>@Localizer["Name"]</th>
					<th>@Localizer["Email"]</th>
					<th>@Localizer["Phone"]</th>
					<th>@Localizer["State"]</th>
					<th>@Localizer["Company"]</th>
					<th>@Localizer["Role"]</th>
					<th>@Localizer["LockoutEnd"]</th>
					<th class="text-center">@Localizer["LockUnlockPermission"]</th>
				</tr>
			</thead>
		</table>
	</div>
</div>
@section Scripts{
	<script src="~/js/user.js"></script>
}