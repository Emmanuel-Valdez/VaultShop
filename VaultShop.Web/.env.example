# Copy this file to .env and replace placeholder values before running the app directly.
# Do not commit .env.
# This file documents the variables the app reads via DotNetEnv + environment variables.
# For Docker Compose deployment, use .env.compose in the repo root instead.

# Database Connection (PostgreSQL)
# Format: Host=server;Port=5432;Database=name;Username=user;Password=pass
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=vaultshop;Username=vaultshop_app;Password=Change_this_Postgres_Password_123!

# Set to true only for initial database setup; keep false for normal operation.
Database__RunMigrationsOnStartup=true

# Stripe Payment Gateway
Stripe__SecretKey=sk_test_replace_me
Stripe__PublishableKey=pk_test_replace_me
Stripe__WebhookSecret=whsec_replace_me

# Facebook OAuth (optional)
Facebook__AppId=replace_me
Facebook__AppSecret=replace_me

# Email Configuration
# Use Fake for local/demo environments. Use Resend for real transactional email.
Email__Provider=Fake
Email__UseFakeEmailSender=true
Resend__ApiKey=re_replace_me
Resend__FromEmail=onboarding@resend.dev

# User Admin Credentials (for seeding initial admin user on first run)
Seed__AdminEmail=admin@example.local
Seed__AdminPassword=Change_this_Admin_Password_123!

# Public Site URL (used for canonical URLs, Open Graph, robots.txt, and sitemap.xml)
SiteUrl=http://localhost:8080

# Public branding. Override these for a different deployment/client.
# Private assets should be mounted or copied outside git.
Branding__PublicName=VaultShop
Branding__LogoPath=/images/brand/vaultshop-logo.svg
Branding__LogoDarkPath=/images/brand/vaultshop-logo-dark.svg
Branding__MarkPath=/images/brand/vaultshop-mark.svg
Branding__AppleTouchIconPath=/images/brand/vaultshop-mark.svg
Branding__SocialPreviewImagePath=/images/brand/vaultshop-og.svg
Branding__TwitterSite=@VaultShop

# Public theme colors. Only hex colors are accepted; invalid values fall back to VaultShop defaults.
Theme__Primary=#1a2a4a
Theme__PrimaryDark=#0d1625
Theme__Accent=#d4a017
Theme__Surface=#f7f8fa
Theme__SurfaceDark=#1e2030

# Image Storage
# Keep Local by default; set Minio to store product images in MinIO.
ImageStorage__Provider=Local
ImageStorage__Minio__Endpoint=localhost:9000
ImageStorage__Minio__UseSsl=false
ImageStorage__Minio__BucketName=product-images
ImageStorage__Minio__AccessKey=minioadmin
ImageStorage__Minio__SecretKey=Change_this_MinIO_Password_123!
ImageStorage__Minio__PublicBaseUrl=http://localhost:9000/product-images

# Social Media Links (displayed in the footer)
Social__TikTok=your_tiktok_link
Social__WhatsApp=your_whatsapp_link
Social__Instagram=your_instagram_link
Social__Facebook=your_facebook_link
Social__DevLink=your_devlink_link

# Manual payment approval (development only; keep commented out in production)
# Payments__AllowDevelopmentManualApproval=false
